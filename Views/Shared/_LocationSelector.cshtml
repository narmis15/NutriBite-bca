@* Partial: location selector modal. Include this partial near navbar in _PublicLayout.cshtml *@
<!-- dynamic NUTRIBITE.Models.UserLocation-->

<div class="modal fade" id="locationModal" tabindex="-1" aria-labelledby="locationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="locationModalLabel">Choose delivery location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <div id="locationLoader" class="text-center my-3" style="display:none;">
                    <div class="spinner-border text-success" role="status"></div>
                    <div class="mt-2">Detecting your location…</div>
                </div>

                <div id="detectedLocation" style="display:none;">
                    <p class="small text-muted">Detected address:</p>
                    <p id="detectedAddress" class="fw-semibold"></p>
                    <button id="confirmDetected" class="btn btn-success btn-sm">Use this location</button>
                </div>

                <hr />

                <div>
                    <label class="form-label">Search for address</label>
                    <input id="locationSearchInput" class="form-control" placeholder="Enter area, city, pincode..." autocomplete="off" />
                    <div id="searchResults" class="list-group mt-2"></div>
                </div>

                <div class="mt-3">
                    <small class="text-muted">If location access is denied you can search and save an address manually.</small>
                </div>

            </div>
            <div class="modal-footer">
                <button id="btnDetectNow" type="button" class="btn btn-outline-success">Detect current location</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>