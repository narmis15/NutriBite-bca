@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/vendor-dashboard.css" asp-append-version="true" />
   <!-- <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
     <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />-->

    @RenderSection("Styles", required: false)

   
</head>
<body>

    <!-- ===== EXACT SAME NAVBAR FROM PUBLIC LAYOUT ===== -->
    

    <!-- ===== VENDOR WRAPPER (sidebar + content) ===== -->
    <div class="vendor-wrapper">

        <!-- Sidebar -->
        <div class="vendor-sidebar" id="vendorSidebar">
            


            <button class="sidebar-toggle" onclick="toggleSidebar()">&#9776;</button>

            <div class="sidebar-section-label"></div>

            <a href="/Vendor/Dashboard">
                <span class="nav-icon">📊</span>
                <span class="nav-label">Dashboard</span>
            </a>
            <a href="/Vendor/MyFood">
                <span class="nav-icon">🍽️</span>
                <span class="nav-label">My Foods</span>
            </a>
            <a href="/Vendor/AddFood">
                <span class="nav-icon">➕</span>
                <span class="nav-label">Add Food</span>
            </a>
            <a href="/Vendor/Order">
                <span class="nav-icon">📦</span>
                <span class="nav-label">Orders</span>
            </a>

            <div class="sidebar-divider"></div>
            <div class="sidebar-section-label"></div>

            <a href="/Vendor/Profile">
                <span class="nav-icon">👤</span>
                <span class="nav-label">Profile</span>
            </a>
            <a href="/Vendor/Logout" class="logout-link">
                <span class="nav-icon">🚪</span>
                <span class="nav-label">Logout</span>
            </a>
        </div>

        <!-- Main Content -->
        <div class="vendor-main" id="vendorMain">
            @RenderBody()
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_AuthModal")

    @RenderSection("Scripts", required: false)

    <script>
        function toggleSidebar() {
            document.getElementById('vendorSidebar').classList.toggle('collapsed');
            document.getElementById('vendorMain').classList.toggle('collapsed');
        }

        // Highlight active sidebar link
        const links = document.querySelectorAll('.vendor-sidebar a');
        links.forEach(link => {
            if (window.location.pathname === new URL(link.href).pathname) {
                link.classList.add('active');
            }
        });

        
    </script>

</body>
</html>