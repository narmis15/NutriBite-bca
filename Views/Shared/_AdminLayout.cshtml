<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NUTRIBITE Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <!-- Toastify for notifications -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    @RenderSection("Styles", required: false)
</head>

<body>

<div class="admin-wrapper">

    <!-- SIDEBAR -->
    @await Html.PartialAsync("_AdminSidebar")

    <!-- CONTENT -->
    <div class="content">
        <div class="topbar"></div>

        @RenderBody()
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Global utility for notifications
        window.notify = {
            success: function(msg) {
                Toastify({
                    text: msg,
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    style: { background: "#22c55e" }
                }).showToast();
            },
            error: function(msg) {
                Toastify({
                    text: msg,
                    duration: 5000,
                    gravity: "top",
                    position: "right",
                    style: { background: "#ef4444" }
                }).showToast();
            },
            info: function(msg) {
                Toastify({
                    text: msg,
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    style: { background: "#3b82f6" }
                }).showToast();
            }
        };

        // Show TempData messages if any
        @if (TempData["Success"] != null) { <text>notify.success("@TempData["Success"]");</text> }
        @if (TempData["Error"] != null) { <text>notify.error("@TempData["Error"]");</text> }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>