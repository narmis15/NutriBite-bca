@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg,#d9f3e8,#c3eadb,#b1e3cf);
            margin: 0;
        }

        .page-wrapper {
            width: 92%;
            max-width: 1300px;
            margin: 50px auto;
            background: #f6fff9;
            border-radius: 30px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        .public-navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: white;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .logo-img {
            height: 55px;
        }

        .nav-center {
            display: flex;
            gap: 40px;
        }

            .nav-center a {
                text-decoration: none;
                font-weight: 600;
                color: #1b4332;
                transition: 0.3s;
            }

                .nav-center a:hover {
                    color: #40916c;
                }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .cart-icon {
            font-size: 22px;
            text-decoration: none;
            transition: 0.3s;
        }

            .cart-icon:hover {
                transform: scale(1.15);
            }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #1b9e52;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(27,158,82,0.4);
        }

            .profile-avatar:hover {
                transform: scale(1.05);
            }

        .dropdown-menu {
            border-radius: 15px;
            padding: 10px;
        }

        .dropdown-item {
            border-radius: 8px;
        }

            .dropdown-item:hover {
                background: #f1f5f3;
            }

        main {
            padding: 40px;
        }

        .nav-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .vendor-btn {
            padding: 10px 18px;
            border-radius: 25px;
            border: 2px solid #52b788;
            color: #1b4332;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

            .vendor-btn:hover {
                background: #52b788;
                color: white;
            }

        .login-btn {
            padding: 10px 20px;
            border-radius: 25px;
            background: #2d6a4f;
            color: white;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

            .login-btn:hover {
                background: #1b4332;
            }

        .signup-btn {
            padding: 10px 20px;
            border-radius: 25px;
            border: 2px solid #2d6a4f;
            color: #2d6a4f;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

            .signup-btn:hover {
                background: #2d6a4f;
                color: white;
            }

        .cart-icon {
            font-size: 22px;
            transition: 0.3s;
        }

            .cart-icon:hover {
                transform: scale(1.15);
            }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #1b9e52;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(27,158,82,0.4);
        }
    </style>
</head>

<body>

    <div class="page-wrapper">

        <!-- NAVBAR -->
        <div class="public-navbar">

            <!-- LEFT LOGO -->
            <a asp-controller="Home" asp-action="Index">
                <img src="~/images/hero/Nutribitelogo.png" class="logo-img" />
            </a>

            <!-- CENTER LINKS -->
            <div class="nav-center">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Location" asp-action="Index">Location</a>
                <a asp-controller="Home" asp-action="About">About</a>
            </div>

            <!-- RIGHT SIDE -->
            <div class="nav-actions">

                @if (userId == null)
                {
                    <!-- BEFORE LOGIN (Landing Style Buttons) -->
                    <a class="vendor-btn" asp-controller="Vendor" asp-action="Register">
                        Join as Vendor
                    </a>

                    <a class="login-btn" asp-controller="Auth" asp-action="Login">
                        Login
                    </a>

                    <a class="signup-btn" asp-controller="Auth" asp-action="Register">
                        Sign Up
                    </a>
                }
                else
                {
                    <!-- AFTER LOGIN -->
                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="cart-icon">
                        🛒
                    </a>

                    <div class="dropdown">
                        <div class="profile-avatar dropdown-toggle"
                             data-bs-toggle="dropdown">
                            @userName?.Substring(0, 1).ToUpper()
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <!-- My Profile -->
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Home"
                                   asp-action="MyProfile">
                                    My Profile
                                </a>
                            </li>

                            <!-- Health Survey -->
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="HealthSurvey"
                                   asp-action="Index">
                                    Health Survey
                                </a>
                            </li>

                            <!-- Calorie Tracking -->
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="CalorieTracker"
                                   asp-action="Index">
                  
                                    Calorie Tracking

                                </a>
                            </li>

                            <!-- My Orders -->
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Home"
                                   asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <!-- Logout -->
                            <li>
                                <a class="dropdown-item text-danger"
                                   asp-controller="Auth"
                                   asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                            
                        </ul>
                    </div>
                }

            </div>
        </div>

        <!-- PAGE CONTENT -->
        <main>
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>