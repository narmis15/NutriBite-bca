@model List<object>

<h2>New Vendor Requests</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Vendor Name</th>
            <th>Email</th>
            <th>Registered On</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (dynamic vendor in Model)
        {
            <tr>
                <td>@vendor.VendorName</td>
                <td>@vendor.Email</td>
                <td>@vendor.CreatedAt</td>
                <td>

                    <form asp-action="ApproveVendor" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@vendor.VendorId" />
                        <button type="submit" class="btn btn-success">
                            Approve
                        </button>
                    </form>

                    <form asp-action="RejectVendor" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@vendor.VendorId" />
                        <button type="submit" class="btn btn-danger">
                            Reject
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>