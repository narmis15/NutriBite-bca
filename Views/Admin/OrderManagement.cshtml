@{
    ViewData["Title"] = "Order Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="table-wrapper card-glass p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Order Management</h3>

        <div class="d-flex align-items-center">
            <span id="liveIndicator" class="badge bg-success me-2">Live</span>
            <label class="form-check-label me-2">Auto-refresh</label>
            <input id="autoRefreshToggle" class="form-check-input" type="checkbox" checked />
            <span id="lastUpdated" class="ms-3 text-muted"></span>
        </div>
    </div>

    <!-- Submenu -->
    <nav class="admin-submenu mb-4">
        <a asp-controller="Admin"
           asp-action="OrderDetails"
           class="submenu-link @(ViewContext.RouteData.Values["action"].ToString() == "OrderDetails" ? "active" : "")">
            Order Details
        </a>       
        <a asp-controller="Admin" asp-action="FlaggedOrders" class="submenu-link">Flagged Orders</a>
        <a asp-controller="Admin" asp-action="PickupSlots" class="submenu-link">Pickup Slots</a>
        <a asp-controller="Admin" asp-action="CancelledOrders" class="submenu-link">Cancelled Orders</a>
    </nav>

    <!-- Status tabs -->
    <ul class="nav nav-tabs mb-3" id="statusTabs" role="tablist">
        <li class="nav-item"><a class="nav-link active" data-status="All" href="#">All <span class="badge bg-light text-dark ms-1" id="count-All">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="New" href="#">New <span class="badge bg-light text-dark ms-1" id="count-New">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="Accepted" href="#">Accepted <span class="badge bg-light text-dark ms-1" id="count-Accepted">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="Ready for Pickup" href="#">Ready for Pickup <span class="badge bg-light text-dark ms-1" id="count-Ready for Pickup">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="Picked" href="#">Picked <span class="badge bg-light text-dark ms-1" id="count-Picked">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="Flagged" href="#">Flagged <span class="badge bg-light text-dark ms-1" id="count-Flagged">0</span></a></li>
    </ul>

    <!-- Orders table -->
    <div class="table-responsive">
        <table class="table admin-table" id="ordersTable">
            <thead>
                <tr>
                    <th>Order Id</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Items</th>
                    <th>Type</th>
                    <th>Details</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- rows injected by script -->
            </tbody>
        </table>
    </div>

    <div id="noOrders" class="no-records" style="display:none;">
        No active orders.
    </div>
</div>

<!-- Assign Delivery Modal -->
<div class="modal fade" id="assignDeliveryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content card-glass">
            <div class="modal-header">
                <h5 class="modal-title">Assign Delivery Person</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="assignOrderId" />
                <div class="mb-3">
                    <label class="form-label">Select Delivery Partner</label>
                    <select id="deliveryPersonSelect" class="form-select">
                        <option value="">Loading partners...</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmAssignBtn" class="btn btn-primary">Assign Now</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
        (function ($) {
            const pollIntervalMs = 10000; // 10s
            let pollTimer = null;
            let currentFilter = "All";
            const token = $('input[name="__RequestVerificationToken"]').first().val();

            const statusClass = {
                "New": "order-row-new",
                "Accepted": "order-row-accepted",
                "Ready for Pickup": "order-row-ready",
                "Picked": "order-row-picked",
                "Flagged": "order-row-flagged"
            };

            function formatBadge(status) {
                let cls = "badge bg-secondary";
                if (status === "New") cls = "badge bg-warning text-dark";
                else if (status === "Accepted") cls = "badge bg-info text-dark";
                else if (status === "Ready for Pickup") cls = "badge bg-success";
                else if (status === "Picked") cls = "badge bg-primary";
                else if (status === "Flagged") cls = "badge bg-danger";
                return '<span class="' + cls + '">' + status + '</span>';
            }

            function buildActionButtons(order) {
                let btns = [];
                if (order.Status === "New") {
                    btns.push('<button class="btn btn-sm glow btn-success action-btn" data-action="AcceptOrder" data-id="' + order.OrderId + '">Accept</button>');
                } else if (order.Status === "Accepted") {
                    btns.push('<button class="btn btn-sm glow btn-warning action-btn" data-action="MarkReady" data-id="' + order.OrderId + '">Mark Ready</button>');
                } else if (order.Status === "Ready for Pickup" && order.OrderType === "Pickup") {
                    btns.push('<button class="btn btn-sm glow btn-primary action-btn" data-action="MarkPicked" data-id="' + order.OrderId + '">Mark Picked</button>');
                }

                if (order.OrderType === "Delivery" && (order.Status === "Accepted" || order.Status === "Ready for Pickup")) {
                    if (!order.DeliveryPersonId) {
                        btns.push('<button class="btn btn-sm glow btn-info assign-delivery-btn" data-id="' + order.OrderId + '">Assign Delivery</button>');
                    } else {
                        btns.push('<span class="badge bg-info d-block mb-1">Assigned</span>');
                    }
                }

                const flagLabel = order.IsFlagged ? 'Unflag' : 'Flag';
                btns.push('<button class="btn btn-sm btn-outline-danger action-btn ms-1" data-action="ToggleFlag" data-id="' + order.OrderId + '">' + flagLabel + '</button>');
                return btns.join('');
            }

            function renderOrders(list) {
                const $tbody = $('#ordersTable tbody');
                $tbody.empty();

                if (!list || list.length === 0) {
                    $('#noOrders').show();
                    $('#ordersTable').hide();
                    return;
                }

                $('#noOrders').hide();
                $('#ordersTable').show();

                const counts = { "All": list.length, "New": 0, "Accepted": 0, "Ready for Pickup": 0, "Picked": 0, "Flagged": 0 };
                list.forEach(o => {
                    if (counts[o.Status] !== undefined) counts[o.Status]++;
                    if (o.IsFlagged) counts["Flagged"]++;
                });

                for (const k in counts) {
                    const id = 'count-' + k;
                    $('#' + id.replace(/\s/g, '\\ ')).text(counts[k]);
                }

                list.forEach(order => {
                    const cls = statusClass[order.Status] || '';
                    if (currentFilter !== "All" && currentFilter !== order.Status && !(currentFilter === "Flagged" && order.IsFlagged)) {
                        return;
                    }

                    const flaggedIcon = order.IsFlagged ? '<span class="order-warning ms-2" title="Flagged">⚠</span>' : '';
                    const orderLink = '<a href="/Admin/OrderDetails?orderId=' + order.OrderId + '">#' + order.OrderId + '</a>';
                    const orderDate = order.CreatedAt ? new Date(order.CreatedAt).toLocaleString() : '-';
                    const orderAmount = '₹' + (order.Amount ?? 0).toFixed(2);

                    const $tr = $('<tr>').addClass(cls).attr('data-id', order.OrderId);
                    $tr.append($('<td>').html(orderLink + (order.IsFlagged ? ' <span class="text-danger ms-1">⚑</span>' : '')));
                    $tr.append($('<td>').text(orderDate));
                    $tr.append($('<td>').text((order.CustomerName || '') + ' • ' + (order.CustomerPhone || '')));
                    $tr.append($('<td>').text(orderAmount));
                    $tr.append($('<td>').text(order.TotalItems));
                    
                    // Type & Details
                    const typeBadge = order.OrderType === 'Delivery' ? '<span class="badge bg-purple">Delivery</span>' : '<span class="badge bg-secondary">Pickup</span>';
                    $tr.append($('<td>').html(typeBadge));
                    
                    const details = order.OrderType === 'Delivery' ? (order.DeliveryAddress || 'No Address') : (order.PickupSlot || 'No Slot');
                    const deliveryInfo = order.OrderType === 'Delivery' ? `<br/><small class="text-info">${order.DeliveryStatus || 'Unassigned'}</small>` : '';
                    $tr.append($('<td>').html(details + deliveryInfo));
                    
                    $tr.append($('<td>').text(order.PaymentStatus || ''));
                    $tr.append($('<td>').html(formatBadge(order.Status) + flaggedIcon));
                    $tr.append($('<td>').html(buildActionButtons(order)));

                    $tbody.append($tr);
                });
                $('#lastUpdated').text('Updated: ' + new Date().toLocaleTimeString());
            }

            function fetchOrders() {
                $.ajax({
                    url: '/Admin/GetActiveOrders',
                    method: 'GET',
                    dataType: 'json',
                    success: function (data) { renderOrders(data); },
                    error: function () { $('#liveIndicator').removeClass('bg-success').addClass('bg-danger').text('Disconnected'); }
                });
            }

            $(document).on('click', '.action-btn', function (e) {
                e.preventDefault();
                const $btn = $(this);
                const action = $btn.data('action');
                const id = $btn.data('id');

                $btn.prop('disabled', true);
                $.post({
                    url: '/Admin/' + action,
                    data: { orderId: id, __RequestVerificationToken: token },
                    dataType: 'json',
                    success: function (res) {
                        if (res.success) {
                            fetchOrders();
                        } else {
                            alert(res.message || 'Action failed');
                            $btn.prop('disabled', false);
                        }
                    },
                    error: function () {
                        alert('Error processing action');
                        $btn.prop('disabled', false);
                    }
                });
            });

            // Delivery Assignment Handlers
            $(document).on('click', '.assign-delivery-btn', function () {
                const orderId = $(this).data('id');
                $('#assignOrderId').val(orderId);
                $('#assignDeliveryModal').modal('show');

                // Fetch personnel
                $.get('/Admin/GetDeliveryPersonnel', function (data) {
                    const $select = $('#deliveryPersonSelect').empty();
                    if (!data || data.length === 0) {
                        $select.append('<option value="">No partners found</option>');
                        return;
                    }
                    data.forEach(p => {
                        $select.append(`<option value="${p.id}">${p.name} (${p.phone})</option>`);
                    });
                });
            });

            $('#confirmAssignBtn').on('click', function () {
                const orderId = $('#assignOrderId').val();
                const personId = $('#deliveryPersonSelect').val();

                if (!personId) {
                    alert('Please select a delivery partner');
                    return;
                }

                $(this).prop('disabled', true).text('Assigning...');

                $.post({
                    url: '/Admin/AssignDelivery',
                    data: { orderId: orderId, deliveryPersonId: personId, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) {
                            $('#assignDeliveryModal').modal('hide');
                            fetchOrders();
                        } else {
                            alert(res.message || 'Failed to assign');
                        }
                    },
                    complete: function () {
                        $('#confirmAssignBtn').prop('disabled', false).text('Assign Now');
                    }
                });
            });

            $('#statusTabs').on('click', 'a', function (e) {
                e.preventDefault();
                $('#statusTabs a').removeClass('active');
                $(this).addClass('active');
                currentFilter = $(this).data('status');
                fetchOrders();
            });

            $('#autoRefreshToggle').on('change', function () {
                const enabled = $(this).is(':checked');
                if (enabled) startPolling(); else stopPolling();
            });

            function startPolling() {
                if (pollTimer) return;
                pollTimer = setInterval(fetchOrders, pollIntervalMs);
                fetchOrders();
            }

            function stopPolling() {
                if (!pollTimer) return;
                clearInterval(pollTimer);
                pollTimer = null;
            }

            $(function () { startPolling(); $(document).on('orders:refresh', fetchOrders); });
        })(jQuery);
    </script>
}
