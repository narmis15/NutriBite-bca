@{
    ViewData["Title"] = "Vendor Payouts Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Vendor Payouts</h2>
            <p class="text-muted">Manage and verify payments to vendors across the platform.</p>
        </div>
        <div class="d-flex gap-2">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-event"></i></span>
                <input type="date" id="payoutDayPicker" class="form-control border-start-0" value="@DateTime.Now.AddDays(-1).ToString("yyyy-MM-dd")" />
                <button id="btnProcessDaily" class="btn btn-primary text-nowrap">
                    Process Daily
                </button>
            </div>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-range"></i></span>
                <input type="month" id="payoutMonthPicker" class="form-control border-start-0" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM")" />
                <button id="btnProcessMonthly" class="btn btn-success text-nowrap">
                    Process Monthly
                </button>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="card border-0 shadow-sm p-3 mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-3">
                <label class="small fw-bold text-muted mb-1">Status</label>
                <select id="statusFilter" class="form-select">
                    <option value="" selected>All Statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="PaidToVendor">Paid</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="small fw-bold text-muted mb-1">Search Vendor</label>
                <input type="text" id="vendorSearch" class="form-control" placeholder="Vendor Name or Email..." />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button id="applyFilters" class="btn btn-primary w-100">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- Payouts Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Details</th>
                        <th>Vendor</th>
                        <th>Period</th>
                        <th>Total Sales</th>
                        <th>Commission (10%)</th>
                        <th>Vendor Amount</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="payoutsBody">
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="card-footer bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">Showing <span id="showingCount">0</span> of <span id="totalCount">0</span> payouts</div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0" id="pagination">
                        <!-- Pagination injected here -->
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="payoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Confirm Payout</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to mark this payout as <strong>Paid</strong>? This action will update the vendor's records and cannot be undone.</p>
                <div class="p-3 bg-light rounded">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Vendor:</span>
                        <span id="modalVendor" class="fw-bold"></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Amount:</span>
                        <span id="modalAmount" class="fw-bold text-success"></span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmPayoutBtn" class="btn btn-success px-4">Confirm Payment</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentPage = 1;
        const pageSize = 20;
        let selectedPayoutId = null;
        const token = $('input[name="__RequestVerificationToken"]').first().val() || '';
        const payoutModal = new bootstrap.Modal(document.getElementById('payoutModal'));

        async function loadPayouts(page = 1) {
            const status = document.getElementById('statusFilter').value;
            const search = document.getElementById('vendorSearch').value;
            const body = document.getElementById('payoutsBody');
            
            // Show loading spinner
            body.innerHTML = `<tr><td colspan="7" class="text-center py-5">
                <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                <div class="mt-2 text-muted small">Loading payouts...</div>
            </td></tr>`;

            try {
                const response = await fetch(`/Admin/GetPayoutsList?page=${page}&pageSize=${pageSize}&status=${status}&search=${search}`);
                
                if (response.ok) {
                    const data = await response.json();
                    renderPayouts(data.items);
                    renderPagination(data.totalItems, data.page, data.pageSize);
                    document.getElementById('showingCount').textContent = data.items.length;
                    document.getElementById('totalCount').textContent = data.totalItems;
                    currentPage = data.page;
                } else if (response.status === 401) {
                    body.innerHTML = '<tr><td colspan="7" class="text-center py-5"><div class="text-danger fw-bold">Unauthorized. Please log in as Admin.</div></td></tr>';
                } else {
                    body.innerHTML = '<tr><td colspan="7" class="text-center py-5"><div class="text-danger">Error loading data (Status: ' + response.status + '). Please try again.</div></td></tr>';
                }
            } catch (error) {
                console.error('Error loading payouts:', error);
                body.innerHTML = '<tr><td colspan="7" class="text-center py-5"><div class="text-danger">Network error. Please check your connection.</div></td></tr>';
            }
        }

        function renderPayouts(payouts) {
            const body = document.getElementById('payoutsBody');
            if (payouts.length === 0) {
                body.innerHTML = '<tr><td colspan="8" class="text-center py-5">No payouts found matching your filters.</td></tr>';
                return;
            }

            body.innerHTML = payouts.map(p => `
                <tr>
                    <td class="ps-4">
                        ${p.id === 0 ? `<span class="badge bg-warning-subtle text-warning border">Unprocessed Balance</span>` : 
                          (p.period && p.period.length > 7 ? `<span class="badge bg-info-subtle text-info border">Daily Payout</span>` : `<span class="badge bg-primary">Monthly Aggregate</span>`)}
                        <div class="text-muted extra-small">ID: ${p.id === 0 ? 'ACC-NEW' : '#' + p.id}</div>
                    </td>
                    <td>
                        <div class="fw-bold">${p.vendorName}</div>
                        <div class="text-muted small">${p.vendorEmail}</div>
                    </td>
                    <td>
                        <div class="fw-bold">${p.period || 'N/A'}</div>
                    </td>
                    <td>₹${p.totalSales.toFixed(2)}</td>
                    <td class="text-danger">- ₹${p.commission.toFixed(2)}</td>
                    <td class="fw-bold text-success">₹${p.amount.toFixed(2)}</td>
                    <td>
                        <span class="badge ${p.status === 'Pending' || p.status === 'Accruing' ? 'bg-warning-subtle text-warning' : 'bg-success-subtle text-success'} rounded-pill px-3">
                            ${p.status === 'PaidToVendor' ? 'Paid' : (p.status === 'Accruing' ? 'Live Balance' : p.status)}
                        </span>
                    </td>
                    <td class="text-end pe-4">
                        ${p.status === 'Pending' || p.status === 'Accruing' ? `
                            <button class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold" onclick="initiateRazorpayPayout(${p.id}, '${p.vendorName}', ${p.amount}, ${p.vendorId})">
                                <i class="bi bi-credit-card me-1"></i> Pay Now
                            </button>
                        ` : `
                            <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold" disabled>
                                <i class="bi bi-check-circle-fill me-1"></i> Paid
                            </button>
                        `}
                    </td>
                </tr>
            `).join('');
        }

        function renderPagination(totalItems, page, size) {
            const totalPages = Math.ceil(totalItems / size);
            const pagination = document.getElementById('pagination');
            
            let html = '';
            for (let i = 1; i <= totalPages; i++) {
                html += `
                    <li class="page-item ${i === page ? 'active' : ''}">
                        <button class="page-link" onclick="loadPayouts(${i})">${i}</button>
                    </li>
                `;
            }
            pagination.innerHTML = html;
        }

        async function initiateRazorpayPayout(id, name, amount, vendorId) {
            // Mocking the Razorpay Payout UI
            const modalHtml = `
                <div class="modal fade" id="payoutModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow">
                            <div class="modal-body text-center p-5">
                                <div class="mb-4">
                                    <i class="bi bi-info-circle text-info display-1"></i>
                                </div>
                                <h3 class="mb-3">Secure Checkout</h3>
                                <p class="text-muted">Mocking payment to <strong>${name}</strong>...</p>
                                <div class="display-4 fw-bold text-success mb-4">₹${amount.toFixed(2)}</div>
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const payoutModal = new bootstrap.Modal(document.getElementById('payoutModal'));
            payoutModal.show();

            // Simulate network delay for payment processing
            setTimeout(async () => {
                try {
                    const response = await fetch(`/Admin/UpdatePayoutStatus?payoutId=${id}&status=PaidToVendor`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    });

                    if (response.ok) {
                        // Success Feedback
                        const modalBody = document.querySelector('#payoutModal .modal-body');
                        modalBody.innerHTML = `
                            <div class="mb-4">
                                <i class="bi bi-check-circle-fill text-success display-1 pulse"></i>
                            </div>
                            <h3 class="mb-3">Payment Successful!</h3>
                            <p class="text-muted">Funds have been transferred to ${name}.</p>
                            <div class="alert alert-success small py-2 mb-4">
                                <strong>Transaction ID:</strong> PAY_${Math.random().toString(36).substr(2, 9).toUpperCase()}
                            </div>
                            <button type="button" class="btn btn-success rounded-pill px-5" data-bs-dismiss="modal">Done</button>
                        `;
                        
                        // Refresh the table when modal is closed
                        document.getElementById('payoutModal').addEventListener('hidden.bs.modal', function () {
                            document.getElementById('payoutModal').remove();
                            loadPayouts(currentPage);
                        });
                    } else {
                        throw new Error('Payment processing failed');
                    }
                } catch (error) {
                    payoutModal.hide();
                    document.getElementById('payoutModal').remove();
                    alert('Error processing payment: ' + error.message);
                }
            }, 2500);
        }

        async function processPayoutInternal(payoutId, vendorId) {
            try {
                const response = await fetch(`/Admin/UpdatePayoutStatus`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        payoutId: payoutId || 0,
                        vendorId: vendorId || 0,
                        status: 'PaidToVendor',
                        __RequestVerificationToken: token
                    })
                });

                const res = await response.json();
                if (res.success) {
                    if (typeof notify !== 'undefined') notify.success('Payout processed successfully through Razorpay.');
                    else alert('Payout processed successfully through Razorpay.');
                    loadPayouts(currentPage);
                } else {
                    if (typeof notify !== 'undefined') notify.error(res.message || 'Failed to process payout. Please try again.');
                    else alert(res.message || 'Failed to process payout. Please try again.');
                }
            } catch (error) {
                console.error('Error processing payout:', error);
            }
        }

        document.getElementById('applyFilters').addEventListener('click', () => loadPayouts(1));

        document.getElementById('btnProcessDaily').addEventListener('click', async () => {
            const val = document.getElementById('payoutDayPicker').value;
            if(!val) return;
            
            if(!confirm(`Are you sure you want to process daily payouts for ${val}?`)) return;

            const btn = document.getElementById('btnProcessDaily');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';

            try {
                const response = await fetch(`/Admin/GenerateDailyPayouts?date=${val}`, { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        __RequestVerificationToken: token
                    })
                });
                const res = await response.json();
                alert(res.message);
                if(res.success) loadPayouts(1);
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Process Daily';
            }
        });

        document.getElementById('btnProcessMonthly').addEventListener('click', async () => {
            const val = document.getElementById('payoutMonthPicker').value;
            if(!val) return;
            const [year, month] = val.split('-');
            
            if(!confirm(`Are you sure you want to process monthly payouts for ${val}?`)) return;

            const btn = document.getElementById('btnProcessMonthly');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';

            try {
                const response = await fetch(`/Admin/GenerateMonthlyPayouts?year=${year}&month=${month}`, { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        __RequestVerificationToken: token
                    })
                });
                const res = await response.json();
                alert(res.message);
                if(res.success) loadPayouts(1);
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-gear-fill"></i> Process Monthly';
            }
        });

        // Initial Load
        loadPayouts();
    </script>
}
