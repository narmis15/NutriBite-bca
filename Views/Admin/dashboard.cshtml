 @{
ViewData["Title"] = "Nutribite Admin Dashboard";
// Use the same shared admin layout used by other admin pages
    //Layout = "~/Views/Shared/_Layout.cshtml";link rel="stylesheet" href="~/css/admin-dashboard.css" />

}
@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}
<div class="dashboard-wrapper">

    <h2 class="dashboard-title">Admin Dashboard</h2>

    <div class="dashboard-grid">

        <div class="db-card">
            <div class="db-icon">👥</div>
            <div class="db-number">@ViewBag.Users</div>
            <div class="db-label">Total Users</div>
        </div>

        <div class="db-card">
            <div class="db-icon">🏪</div>
            <div class="db-number">@ViewBag.Vendors</div>
            <div class="db-label">Total Vendors</div>
        </div>

        <div class="db-card">
            <div class="db-icon">📦</div>
            <div class="db-number">@ViewBag.Orders</div>
            <div class="db-label">Total Orders</div>
        </div>

        <div class="db-card">
            <div class="db-icon">🛒</div>
            <div class="db-number">@ViewBag.Products</div>
            <div class="db-label">Products Sold</div>
        </div>

        <div class="db-card">
            <div class="db-icon">💰</div>
            <div class="db-number">₹ @ViewBag.TotalAmount</div>
            <div class="db-label">Total Revenue</div>
        </div>

        <div class="db-card">
            <div class="db-icon">📊</div>
            <div class="db-number">₹ @ViewBag.Profit</div>
            <div class="db-label">Profit Share (15%)</div>
        </div>

        <div class="db-card">
            <div class="db-icon">📅</div>
            <div class="db-number">₹ @ViewBag.WeeklyRevenue</div>
            <div class="db-label">Weekly Revenue (7d)</div>
        </div>

        <div class="db-card">
            <div class="db-icon">📈</div>
            <div class="db-number">₹ @ViewBag.WeeklyProfit</div>
            <div class="db-label">Weekly Profit (15%)</div>
        </div>

        <div class="db-card">
            <div class="db-icon">🗓️</div>
            <div class="db-number">₹ @ViewBag.MonthlyRevenue</div>
            <div class="db-label">Monthly Revenue</div>
        </div>

        <div class="db-card">
            <div class="db-icon">💹</div>
            <div class="db-number">₹ @ViewBag.MonthlyProfit</div>
            <div class="db-label">Monthly Profit (15%)</div>
        </div>

    </div>

</div>
