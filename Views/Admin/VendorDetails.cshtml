@model NUTRIBITE.Models.VendorSignup

@{
    ViewData["Title"] = "Vendor Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ManageVendor" class="btn btn-light rounded-circle me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0">Vendor Details</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="ManageVendor">Vendors</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.VendorName</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Profile Card -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="mb-4">
                        <div class="vendor-avatar-large mx-auto shadow-sm">
                            @Model.VendorName.Substring(0, 1).ToUpper()
                        </div>
                    </div>
                    <h4 class="fw-bold mb-1">@Model.VendorName</h4>
                    <p class="text-muted small mb-3">ID: #@Model.VendorId</p>
                    
                    <div class="mb-4">
                        @if (Model.IsApproved)
                        {
                            <span class="badge bg-soft-success text-success rounded-pill px-4 py-2 border border-success border-opacity-25">
                                <i class="bi bi-check-circle-fill me-1"></i> Approved
                            </span>
                        }
                        else if (Model.IsRejected)
                        {
                            <span class="badge bg-soft-danger text-danger rounded-pill px-4 py-2 border border-danger border-opacity-25">
                                <i class="bi bi-x-circle-fill me-1"></i> Rejected
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-soft-warning text-warning rounded-pill px-4 py-2 border border-warning border-opacity-25">
                                <i class="bi bi-clock-fill me-1"></i> Pending Review
                            </span>
                        }
                    </div>

                    <hr class="my-4 opacity-50">

                    <div class="text-start">
                        <label class="text-muted extra-small text-uppercase fw-bold mb-2">About Vendor</label>
                        <p class="small text-dark mb-0">@(Model.Description ?? "No description provided.")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Details & Information -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">General Information</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bi bi-envelope text-primary me-2"></i>
                                <span class="text-muted small fw-semibold">Email Address</span>
                            </div>
                            <div class="fw-medium text-dark ps-4">@Model.Email</div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bi bi-telephone text-primary me-2"></i>
                                <span class="text-muted small fw-semibold">Phone Number</span>
                            </div>
                            <div class="fw-medium text-dark ps-4">@(Model.Phone ?? "Not Provided")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bi bi-geo-alt text-primary me-2"></i>
                                <span class="text-muted small fw-semibold">Physical Address</span>
                            </div>
                            <div class="fw-medium text-dark ps-4">@(Model.Address ?? "Not Provided")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bi bi-calendar-event text-primary me-2"></i>
                                <span class="text-muted small fw-semibold">Joined Date</span>
                            </div>
                            <div class="fw-medium text-dark ps-4">@(Model.CreatedAt?.ToString("dd MMMM yyyy") ?? "-")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4">
                            <h5 class="fw-bold mb-0">Business Hours</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-light">
                                <span class="text-muted small">Opening Time</span>
                                <span class="fw-bold text-success">@(Model.OpeningHours ?? "N/A")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">Closing Time</span>
                                <span class="fw-bold text-danger">@(Model.ClosingHours ?? "N/A")</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4">
                            <h5 class="fw-bold mb-0">Financial Info</h5>
                        </div>
                        <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                            <div class="text-muted small mb-1">UPI ID for Payouts</div>
                            <div class="fw-bold text-dark fs-5">@(Model.UpiId ?? "Not Linked")</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (!Model.IsApproved && !Model.IsRejected)
            {
                <div class="card border-0 shadow-sm mt-4 bg-light">
                    <div class="card-body p-4 d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">Pending Approval</h6>
                            <p class="text-muted small mb-0">This vendor is waiting for verification to start selling.</p>
                        </div>
                        <div class="d-flex gap-2">
                            <form asp-action="RejectVendor" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.VendorId" />
                                <button type="submit" class="btn btn-outline-danger px-4">Reject</button>
                            </form>
                            <form asp-action="ApproveVendor" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.VendorId" />
                                <button type="submit" class="btn btn-success px-4">Approve Vendor</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .vendor-avatar-large {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 3rem;
    }
    .bg-soft-success { background-color: rgba(34, 197, 94, 0.1); }
    .bg-soft-danger { background-color: rgba(239, 68, 68, 0.1); }
    .bg-soft-warning { background-color: rgba(245, 158, 11, 0.1); }
    .extra-small { font-size: 0.75rem; letter-spacing: 0.05em; }
    .breadcrumb-item a { color: #6c757d; text-decoration: none; }
    .breadcrumb-item.active { color: #16a34a; font-weight: 600; }
</style>
