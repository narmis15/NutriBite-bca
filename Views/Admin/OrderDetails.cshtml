@{
    ViewData["Title"] = "Order Details";
}
@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
}

<div class="card-glass p-4">
    <h3>Order Details</h3>

    <div id="orderDetailsContainer">
        <p class="text-muted">Select an order from Order Management or refresh this page with ?id={orderId}.</p>
    </div>
</div>

@section Scripts {
<script>
    (function() {
        const orderId = '@(ViewBag.OrderId ?? "")';
        if (!orderId) return;

        fetch(`@Url.Action("GetOrderDetails","Admin")?orderId=${orderId}`)
            .then(r => r.json())
            .then(data => {
                if (data.error) {
                    document.getElementById('orderDetailsContainer').innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
                    return;
                }
                let html = `<dl class="row">
                    <dt class="col-sm-3">Order ID</dt><dd class="col-sm-9">${data.OrderId}</dd>
                    <dt class="col-sm-3">Customer</dt><dd class="col-sm-9">${data.CustomerName} (${data.CustomerPhone})</dd>
                    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">${data.Status}</dd>
                    <dt class="col-sm-3">Type</dt><dd class="col-sm-9"><span class="badge ${data.OrderType === 'Delivery' ? 'bg-purple' : 'bg-secondary'}">${data.OrderType}</span></dd>
                    ${data.OrderType === 'Delivery' 
                        ? `<dt class="col-sm-3">Delivery Address</dt><dd class="col-sm-9">${data.DeliveryAddress}</dd>
                           <dt class="col-sm-3">Delivery Notes</dt><dd class="col-sm-9"><em class="text-muted">${data.DeliveryNotes || 'No notes'}</em></dd>
                           <dt class="col-sm-3">Delivery Status</dt><dd class="col-sm-9">${data.DeliveryStatus || 'Not Assigned'}</dd>`
                        : `<dt class="col-sm-3">Pickup Slot</dt><dd class="col-sm-9">${data.PickupSlot}</dd>`
                    }
                    <dt class="col-sm-3">Total Amount</dt><dd class="col-sm-9">${data.Amount}</dd>
                    <dt class="col-sm-3">Created</dt><dd class="col-sm-9">${data.OrderDateTime}</dd>
                </dl>`;

                html += '<h5>Items</h5><ul>';
                (data.Items || []).forEach(i => {
                    html += `<li>${i.Name} x ${i.Quantity} <small>${i.Instructions || ''}</small></li>`;
                });
                html += '</ul>';

                document.getElementById('orderDetailsContainer').innerHTML = html;
            }).catch(err => {
                document.getElementById('orderDetailsContainer').innerHTML = `<div class="alert alert-danger">Error loading order: ${err}</div>`;
            });
    })();
</script>
}
