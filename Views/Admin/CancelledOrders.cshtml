@{
    ViewData["Title"] = "Cancelled Orders & Refunds";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .refund-badge {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
        }
        .bg-refund-pending { background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; }
        .bg-refund-completed { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .bg-refund-none { background-color: #f8f9fa; color: #6c757d; border: 1px solid #dee2e6; }
        
        .admin-note-text {
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            cursor: pointer;
        }
    </style>
}

@Html.AntiForgeryToken()

<div class="table-wrapper card-glass p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 fw-bold">Cancelled Orders & Refunds</h3>
            <p class="text-muted small mb-0">Manage cancellations, process refunds, and track admin notes</p>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="input-group input-group-sm" style="width: 250px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" id="orderSearch" class="form-control border-start-0" placeholder="Search orders...">
            </div>
            
            <div class="bg-light p-2 rounded-pill shadow-sm d-flex align-items-center">
                <button id="refreshBtn" class="btn btn-sm btn-link text-decoration-none p-0 px-2 me-2">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
                <span id="lastUpdated" class="small text-muted fw-500"></span>
            </div>
        </div>
    </div>

    <!-- Submenu -->
    <nav class="admin-submenu mb-4 d-flex gap-2">
        <a asp-controller="Admin" asp-action="OrderManagement" class="btn btn-sm btn-outline-success rounded-pill px-3">
            Active Management
        </a>
        <a asp-controller="Admin" asp-action="CancelledOrders" class="btn btn-sm btn-danger rounded-pill px-3">
            Cancelled Orders
        </a>
    </nav>

    <!-- Filters -->
    <div class="d-flex gap-2 mb-4">
        <button class="btn btn-sm btn-light rounded-pill px-3 filter-refund active" data-filter="all">All Refunds</button>
        <button class="btn btn-sm btn-light rounded-pill px-3 filter-refund" data-filter="Pending">Pending</button>
        <button class="btn btn-sm btn-light rounded-pill px-3 filter-refund" data-filter="Refunded">Completed</button>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle" id="cancelledTable">
            <thead>
                <tr>
                    <th class="ps-4">Order ID</th>
                    <th>Customer</th>
                    <th>Order Info</th>
                    <th>Reason</th>
                    <th>Refund Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- injected -->
            </tbody>
        </table>
    </div>

    <div id="noCancelled" class="no-records" style="display:none;">
        <div class="py-5 text-center">
            <i class="bi bi-clipboard-x text-muted display-4"></i>
            <p class="mt-3 fs-5">No cancelled orders found.</p>
        </div>
    </div>
</div>

<!-- Order Summary Modal -->
<div class="modal fade" id="summaryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0 pe-4 pt-4">
                <h5 class="modal-title fw-bold" id="summaryTitle">Order Summary</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="summaryBody">
                <!-- Summary content injected here -->
            </div>
        </div>
    </div>
</div>

<!-- Modal for adding admin note -->
<div class="modal fade" id="noteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Admin Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">Add internal notes regarding the cancellation or refund process.</p>
                <textarea id="adminNoteText" class="form-control rounded-3" rows="5" placeholder="Enter internal note..."></textarea>
                <input type="hidden" id="noteOrderId" />
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="saveNoteBtn" class="btn btn-primary rounded-pill px-4">Save Note</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
        (function ($) {
            const token = $('input[name="__RequestVerificationToken"]').first().val();
            let allOrders = [];
            let currentFilter = 'all';

            function formatRefundBadge(status) {
                if (status === 'Refunded') return '<span class="refund-badge bg-refund-completed"><i class="bi bi-check-circle-fill me-1"></i> Refunded</span>';
                if (status === 'Pending') return '<span class="refund-badge bg-refund-pending"><i class="bi bi-clock-fill me-1"></i> Pending</span>';
                return '<span class="refund-badge bg-refund-none">No Refund Info</span>';
            }

            function renderRows(list) {
                const $tbody = $('#cancelledTable tbody').empty();
                
                // Apply filter
                let filtered = list;
                if (currentFilter !== 'all') {
                    filtered = list.filter(o => (o.payment_status || 'Pending') === currentFilter);
                }

                // Apply search
                const search = $('#orderSearch').val().toLowerCase();
                if (search) {
                    filtered = filtered.filter(o => 
                        o.order_id.toString().includes(search) || 
                        (o.customer_name || '').toLowerCase().includes(search) ||
                        (o.customer_contact || '').toLowerCase().includes(search)
                    );
                }

                if (filtered.length === 0) {
                    $('#noCancelled').show();
                    $('#cancelledTable').hide();
                    return;
                }
                
                $('#noCancelled').hide();
                $('#cancelledTable').show();

                filtered.forEach(o => {
                    const orderLink = `<a href="/Admin/OrderDetails?orderId=${o.order_id}" class="fw-bold text-decoration-none text-primary">#${o.order_id}</a>`;
                    const cust = `
                        <div class="d-flex align-items-center">
                            <div class="avatar-sm me-2 bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="bi bi-person text-secondary"></i>
                            </div>
                            <div>
                                <div class="fw-600 text-dark small">${o.customer_name || 'Guest'}</div>
                                <div class="text-muted" style="font-size: 0.7rem;">${o.customer_contact || '-'}</div>
                            </div>
                        </div>`;
                    
                    const orderInfo = `
                        <div>
                            <div class="fw-bold text-dark">₹${(o.refunded_amount || 0).toFixed(2)}</div>
                            <div class="text-muted small">${o.canceled_at ? new Date(o.canceled_at).toLocaleDateString() : '-'}</div>
                        </div>`;
                    
                    const reason = `
                        <div class="small text-muted" title="${o.cancellation_reason || 'No reason provided'}">
                            ${o.cancellation_reason ? (o.cancellation_reason.length > 30 ? o.cancellation_reason.substring(0, 30) + '...' : o.cancellation_reason) : '-'}
                        </div>`;

                    const refundStatus = formatRefundBadge(o.payment_status || 'Pending');
                    
                    const actions = `
                        <div class="text-end pe-3">
                            ${o.payment_status !== 'Refunded' ? 
                                `<button class="btn btn-sm btn-success rounded-pill px-3 mark-refund me-1" data-id="${o.order_id}">Mark Refunded</button>` : 
                                `<button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled><i class="bi bi-check-lg"></i> Refunded</button>`
                            }
                            <button class="btn btn-sm btn-light rounded-pill px-3 add-note" data-id="${o.order_id}" data-note="${o.admin_notes || ''}">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn btn-sm btn-info rounded-pill px-3 view-summary-btn" data-id="${o.order_id}">
                                <i class="bi bi-eye"></i> Show More
                            </button>
                        </div>`;

                    const $tr = $('<tr>');
                    $tr.append($('<td class="ps-4">').html(orderLink));
                    $tr.append($('<td>').html(cust));
                    $tr.append($('<td>').html(orderInfo));
                    $tr.append($('<td>').html(reason));
                    $tr.append($('<td>').html(refundStatus));
                    $tr.append($('<td>').html(actions));
                    $tbody.append($tr);
                });

                $('#lastUpdated').text('Last sync: ' + new Date().toLocaleTimeString());
            }

            function fetchCancelled() {
                $('#cancelledTable tbody').html('<tr><td colspan="6" class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div><span class="ms-2 text-muted small">Loading records...</span></td></tr>');
                
                $.ajax({
                    url: '/Admin/GetCancelledOrders',
                    method: 'GET',
                    dataType: 'json'
                }).done(function (data) {
                    allOrders = data;
                    renderRows(allOrders);
                }).fail(function () {
                    $('#cancelledTable tbody').html('<tr><td colspan="6" class="text-center py-4 text-danger"><i class="bi bi-exclamation-circle me-2"></i>Failed to load cancelled orders.</td></tr>');
                });
            }

            // delegated actions
            $(document).on('click', '.mark-refund', function () {
                const id = $(this).data('id');
                const $btn = $(this);
                if (!confirm('Mark refund as Completed for order #' + id + ' ? This will update the payment status.')) return;
                
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
                
                $.post({
                    url: '/Admin/UpdateRefundStatus',
                    data: { orderId: id, status: 'Completed', __RequestVerificationToken: token },
                    dataType: 'json'
                }).done(function (res) {
                    if (res && res.success) {
                        fetchCancelled();
                    } else {
                        alert(res?.message || 'Failed to update refund status');
                        $btn.prop('disabled', false).text('Mark Refunded');
                    }
                }).fail(function () { 
                    alert('Server error'); 
                    $btn.prop('disabled', false).text('Mark Refunded');
                });
            });

            $(document).on('click', '.add-note', function () {
                const id = $(this).data('id');
                const existingNote = $(this).data('note');
                $('#noteOrderId').val(id);
                $('#adminNoteText').val(existingNote);
                var noteModal = new bootstrap.Modal(document.getElementById('noteModal'));
                noteModal.show();
            });

            $('#saveNoteBtn').on('click', function () {
                const id = $('#noteOrderId').val();
                const note = $('#adminNoteText').val().trim();
                const $btn = $(this);
                
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
                
                $.post({
                    url: '/Admin/AddAdminNote',
                    data: { orderId: id, note: note, __RequestVerificationToken: token },
                    dataType: 'json'
                }).done(function (res) {
                    if (res && res.success) {
                        fetchCancelled();
                        $('#noteModal').modal('hide');
                    } else {
                        alert(res?.message || 'Failed to save note');
                    }
                }).always(function() {
                    $btn.prop('disabled', false).text('Save Note');
                });
            });

            $('#orderSearch').on('input', function() {
                renderRows(allOrders);
            });

            $('.filter-refund').on('click', function() {
                $('.filter-refund').removeClass('active btn-primary').addClass('btn-light');
                $(this).addClass('active btn-primary').removeClass('btn-light');
                currentFilter = $(this).data('filter');
                renderRows(allOrders);
            });

            $('#refreshBtn').on('click', function(e) {
                e.preventDefault();
                fetchCancelled();
            });

            $(function () {
                fetchCancelled();
            });

            $(document).on('click', '.view-summary-btn', function () {
                const orderId = $(this).data('id');
                const order = allOrders.find(o => o.order_id === orderId);

                if (order) {
                    $('#summaryTitle').text(`Order #${order.order_id} - Summary`);

                    const summaryHtml = `
                        <div>
                            <h6>Items Ordered</h6>
                            <p>${order.cancellation_reason}</p> 
                            <hr />
                            <h6>Information</h6>
                            <p><strong>Customer:</strong> ${order.customer_name}</p>
                            <p><strong>Phone:</strong> ${order.customer_contact}</p>
                            <p><strong>Address:</strong> ${order.delivery_address || 'Local Address'}</p>
                            <p><strong>Payment:</strong> ${order.payment_status}</p>
                            <p><strong>Placed At:</strong> ${new Date(order.canceled_at).toLocaleString()}</p>
                        </div>
                    `;

                    $('#summaryBody').html(summaryHtml);
                    var summaryModal = new bootstrap.Modal(document.getElementById('summaryModal'));
                    summaryModal.show();
                }
            });
        })(jQuery);
    </script>
}