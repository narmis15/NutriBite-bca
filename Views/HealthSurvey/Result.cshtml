@model NUTRIBITE.Models.HealthSurvey

@{
    ViewData["Title"] = "Health Result";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    <link rel="stylesheet" href="~/css/Home.css" />
    var foods = ViewBag.FoodSuggestions as List<NUTRIBITE.Models.Food>;

    string bmiStatus = "";

    if (Model.Bmi < 18.5m)
    {
        bmiStatus = "Underweight";
    }
    else if (Model.Bmi >= 18.5m && Model.Bmi <= 24.9m)
    {
        bmiStatus = "Normal Weight";
    }
    else if (Model.Bmi >= 25 && Model.Bmi <= 29.9m)
    {
        bmiStatus = "Overweight";
    }
    else
    {
        bmiStatus = "Obese";
    }

    string healthTip = "";

    if (Model.Bmi < 18.5m)
    {
        healthTip = "Your BMI indicates you may be underweight. Consider increasing calorie intake with balanced meals.";
    }
    else if (Model.Bmi <= 24.9m)
    {
        healthTip = "Your BMI is in the healthy range. Maintain a balanced diet and active lifestyle.";
    }
    else
    {
        healthTip = "Your BMI is above the healthy range. Consider reducing calorie intake and increasing physical activity.";
    }
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Your Health Summary</h3>

        <a href="/HealthSurvey/Edit" class="btn btn-outline-dark">
            ✏ Edit Health Survey
        </a>
    </div>


    <!-- SUMMARY CARDS -->
    <div class="row text-center mb-4">

        <!-- BMI -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6>BMI</h6>
                <h4>@Model.Bmi</h4>

                @if (bmiStatus == "Normal Weight")
                {
                    <span class="badge bg-success">@bmiStatus</span>
                }
                else if (bmiStatus == "Underweight")
                {
                    <span class="badge bg-warning text-dark">@bmiStatus</span>
                }
                else
                {
                    <span class="badge bg-danger">@bmiStatus</span>
                }

            </div>
        </div>

        <!-- BMR -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6>BMR</h6>
                <h4>@Model.Bmr</h4>
                <small>kcal/day</small>
            </div>
        </div>

        <!-- Recommended Calories -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6>Recommended Calories</h6>
                <h4>@Model.RecommendedCalories</h4>
                <small>kcal/day</small>
            </div>
        </div>

    </div>


    <!-- PROFILE -->
    <div class="card p-4 shadow-sm mb-4">

        <h5>Profile</h5>

        <div class="row">

            <div class="col-md-6">
                <p><strong>Age:</strong> @Model.Age</p>
                <p><strong>Height:</strong> @Model.HeightCm cm</p>
                <p><strong>Weight:</strong> @Model.WeightKg kg</p>
            </div>

            <div class="col-md-6">
                <p><strong>Gender:</strong> @Model.Gender</p>
                <p><strong>Diet:</strong> @Model.DietaryPreference</p>
                <p><strong>Activity:</strong> @Model.ActivityLevel</p>
            </div>

        </div>

        <hr />

        <h6>Health Notes</h6>

        <p><strong>Chronic Conditions:</strong> @Model.ChronicDiseases</p>
        <p><strong>Food Allergies:</strong> @Model.FoodAllergies</p>
        <p><strong>Smoking:</strong> @(Model.Smoking ? "Yes" : "No")</p>
        <p><strong>Alcohol:</strong> @(Model.Alcohol ? "Yes" : "No")</p>

    </div>


    <!-- MACROS -->
    <div class="card p-4 shadow-sm mb-4">

        <h5>Macro Distribution</h5>

        <div class="bg-light p-3 rounded">

            <p><strong>Carbs:</strong> 50%</p>
            <p><strong>Protein:</strong> 20%</p>
            <p><strong>Fats:</strong> 30%</p>

        </div>

    </div>


    <!-- HEALTH INSIGHT -->
    <div class="card p-4 shadow-sm mb-4 border-success">

        <h5>💡 Health Insight</h5>

        <p class="mb-1">
            Based on your health survey results:
        </p>

        <p class="fw-bold">
            @healthTip
        </p>

        <p class="text-muted small">
            Your recommended daily calorie intake is
            <strong>@Model.RecommendedCalories kcal</strong>.
            Try to maintain balanced meals to meet your daily nutrition needs.
        </p>

    </div>


    <!-- FOOD RECOMMENDATIONS -->
    <div class="card p-4 shadow-sm mb-4">

        <h5>Recommended Meals For You</h5>

        @if (foods != null && foods.Any())
        {

            <!-- BREAKFAST -->
            <h6 class="mt-3">🍳 Breakfast</h6>

            <div class="row">

                @foreach (var food in foods.Where(f => f.Calories <= 400))
                {
                    <div class="col-md-4 mb-4">

                        <div class="card shadow-sm h-100">

                            <img src="@food.ImagePath"
                                 class="card-img-top"
                                 style="height:200px;object-fit:cover;" />

                            <div class="card-body">

                                <h6 class="card-title">@food.Name</h6>

                                <p class="text-muted small">
                                    @food.Description
                                </p>

                                <p class="text-muted small">
                                    🔥 @food.Calories kcal
                                </p>

                                <span class="badge bg-success mb-2">
                                    Breakfast Option
                                </span>

                                <p class="fw-bold mt-2">
                                    ₹@food.Price
                                </p>

                                <button type="button"
                                        class="btn btn-success addToCartBtn"
                                        data-id="@food.Id">
                                    Add to Cart
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>


            <!-- LUNCH -->
            <h6 class="mt-4">🍛 Lunch</h6>

            <div class="row">

                @foreach (var food in foods.Where(f => f.Calories > 400 && f.Calories <= 700))
                {
                    <div class="col-md-4 mb-4">

                        <div class="card shadow-sm h-100">

                            <img src="@food.ImagePath"
                                 class="card-img-top"
                                 style="height:200px;object-fit:cover;" />

                            <div class="card-body">

                                <h6 class="card-title">@food.Name</h6>

                                <p class="text-muted small">
                                    @food.Description
                                </p>

                                <p class="text-muted small">
                                    🔥 @food.Calories kcal
                                </p>

                                <span class="badge bg-warning text-dark mb-2">
                                    Lunch Option
                                </span>

                                <p class="fw-bold mt-2">
                                    ₹@food.Price
                                </p>

                                <button type="button"
                                        class="btn btn-success addToCartBtn"
                                        data-id="@food.Id">
                                    Add to Cart
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>


            <!-- DINNER -->
            <h6 class="mt-4">🍽 Dinner</h6>

            <div class="row">

                @foreach (var food in foods.Where(f => f.Calories > 700))
                {
                    <div class="col-md-4 mb-4">

                        <div class="card shadow-sm h-100">

                            <img src="@food.ImagePath"
                                 class="card-img-top"
                                 style="height:200px;object-fit:cover;" />

                            <div class="card-body">

                                <h6 class="card-title">@food.Name</h6>

                                <p class="text-muted small">
                                    @food.Description
                                </p>

                                <p class="text-muted small">
                                    🔥 @food.Calories kcal
                                </p>

                                <span class="badge bg-danger mb-2">
                                    Dinner Option
                                </span>

                                <p class="fw-bold mt-2">
                                    ₹@food.Price
                                </p>

                                <button type="button"
                                        class="btn btn-success addToCartBtn"
                                        data-id="@food.Id">
                                    Add to Cart
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>

        }
        else
        {
            <p>No recommended meals available.</p>
        }

    </div>


    <!-- TRUST MESSAGE -->
    <div class="alert alert-info mt-4">

        <strong>Why we collect this information</strong>

        <p class="mb-1">
            Your health data helps NutriBite calculate BMI, BMR, and recommended daily calorie intake.
            This allows us to provide personalized nutrition insights and meal recommendations.
        </p>

        <p class="small text-muted mb-0">
            Your information is kept private and used only to improve your nutrition experience.
        </p>

    </div>




</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(document).ready(function () {

        $(document).on("click", ".addToCartBtn", function () {

            var foodId = $(this).data("id");

            $.ajax({
                url: "/Cart/AddToCart",
                type: "POST",
                data: { foodId: foodId },

                success: function (res) {

                    if (res.success) {

                        alert("Food added to cart");

                        $.get("/Cart/GetCartCount", function (data) {

                            if (data.success) {
                                $("#cartCount").text(data.count);
                            }

                        });

                    }
                    else {

                        alert(res.message);

                    }

                }

            });

        });

    });

</script>
