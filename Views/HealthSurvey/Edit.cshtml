@model NUTRIBITE.ViewModels.HealthSurveyViewModel

@{
    ViewData["Title"] = "Edit Health Survey";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container py-5">
    <div class="card p-4 shadow-lg rounded-4">
        <h3 class="mb-4">Edit Health Information</h3>

        @using (Html.BeginForm("Edit", "HealthSurvey", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Age</label>
                    @Html.TextBoxFor(m => m.Age, new { @class = "form-control", type = "number" })
                </div>

                <div class="col-md-4 mb-3">
                    <label>Gender</label>
                    @Html.DropDownListFor(m => m.Gender,
                    new SelectList(new[] { "Male", "Female", "Other" }),
                                "Select",
                                new { @class = "form-select" })
            </div>

            <div class="col-md-4 mb-3">
                <label>Goal</label>
                @Html.DropDownListFor(m => m.Goal,
                                new SelectList(new[] { "Weight Loss", "Maintain", "Weight Gain", "Muscle Gain" }),
                                "Select",
                                new { @class = "form-select" })
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Height (cm)</label>
                @Html.TextBoxFor(m => m.HeightCm, new { @class = "form-control", type = "number" })
            </div>

            <div class="col-md-6 mb-3">
                <label>Weight (kg)</label>
                @Html.TextBoxFor(m => m.WeightKg, new { @class = "form-control", type = "number" })
            </div>
        </div>

        <div class="mb-3">
            <label>Activity Level</label>
            @Html.DropDownListFor(m => m.ActivityLevel,
                        new SelectList(new[] { "Sedentary", "Lightly Active", "Moderately Active", "Very Active" }),
                        "Select",
                        new { @class = "form-select" })
        </div>

        <div class="mb-3">
            <label>Dietary Preference</label>
            @Html.DropDownListFor(m => m.DietaryPreference,
                        new SelectList(new[] { "Vegetarian", "Vegan", "Eggetarian", "Non-Vegetarian" }),
                        "Select",
                        new { @class = "form-select" })
        </div>

        <div class="mb-3">
            <label>Chronic Diseases</label>
            @Html.TextAreaFor(m => m.ChronicDiseases, new { @class = "form-control", rows = 2 })
        </div>

        <div class="mb-3">
            <label>Food Allergies</label>
            @Html.TextAreaFor(m => m.FoodAllergies, new { @class = "form-control", rows = 2 })
        </div>

        <div class="form-check mb-2">
            @Html.CheckBoxFor(m => m.Smoking)
            <label>I smoke</label>
        </div>

        <div class="form-check mb-4">
            @Html.CheckBoxFor(m => m.Alcohol)
            <label>I consume alcohol</label>
        </div>

        <button type="submit" class="btn btn-success px-4">
            Save Changes
        </button>
                }
    </div>
</div>