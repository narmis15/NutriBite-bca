@{
    ViewData["Title"] = "Bulk Snacks — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="container py-4">

    <!-- Page Title -->
    <div class="mb-4">
        <h2 class="fw-bold">Snacks</h2>
    </div>


    <!-- Packaging Options -->
    <div class="row mb-4">

        <div class="col-md-8">

            <div class="d-flex gap-5">

                <label>
                    <input type="radio" name="packaging" checked />
                    <strong>Individual Packaging</strong>
                    <div class="text-muted small">
                        Each snack packed separately
                    </div>
                    <div class="small">MOQ: 1</div>
                </label>


                <label>
                    <input type="radio" name="packaging" />
                    <strong>Bulk Packaging</strong>
                    <div class="text-muted small">
                        Snacks packed together
                    </div>
                    <div class="small">MOQ: 30</div>
                </label>

            </div>

        </div>


        <!-- Veg Filter -->
        <div class="col-md-4 text-end">

            <span class="diet-pill active" data-val="veg">
                🟢 Veg
            </span>

            <span class="diet-pill" data-val="nonveg">
                🔴 Non Veg
            </span>

        </div>

    </div>



    <!-- Snack List -->
    <div class="row">
        @foreach (var it in items)
        {
            var isVeg = (it.IsVeg ? "veg" : "nonveg");
            var img = (it.ImagePath ?? "/images/bulk/default.jpg").ToString();

            <div class="col-12 mb-3">

                <div class="meal-card card shadow-sm p-3"
                     data-veg="@isVeg">

                    <div class="row align-items-center">

                        <!-- LEFT CONTENT -->
                        <div class="col-md-8">

                            <div class="veg-indicator">
                                @(it.IsVeg ? "🟢" : "🔴")
                            </div>

                            <h5>@it.Name</h5>

                            <div class="price">
                                ₹@it.Price
                            </div>

                            <p class="desc">
                                @(it.Description ?? "")
                            </p>

                        </div>


                        <!-- RIGHT CONTENT -->
                        <div class="col-md-4 text-end">
                        <div class="meal-img-box">
                            <img src="@img"
                                 class="meal-img"
                                 onerror="this.src='/images/bulk/default.jpg'" />
                                 </div>

                            <div class="qty mt-2">

                                <button class="qty-decrease">−</button>

                                <input type="text"
                                       class="qty-input"
                                       value="1" />

                                <button class="qty-increase">+</button>

                            </div>

                            <button class="btn-add-cart mt-2"
                                    data-id="@it.Id">
                                ADD
                            </button>

                        </div>

                    </div>

                </div>

            </div>
        }
    </div>

</div>



@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function(){

            /* Veg / Nonveg filter */

            document.querySelectorAll(".diet-pill").forEach(function(pill){

                pill.addEventListener("click", function(){

                    document.querySelectorAll(".diet-pill")
                        .forEach(p=>p.classList.remove("active"));

                    this.classList.add("active");

                    let val = this.dataset.val;

                    document.querySelectorAll("[data-veg]").forEach(function(card){

                        let type = card.getAttribute("data-veg");

                        card.style.display = (type === val) ? "" : "none";

                    });

                });

            });



            /* Quantity buttons */

            document.querySelectorAll(".qty").forEach(function(box){

                let input = box.querySelector(".qty-input");

                box.querySelector(".qty-decrease")
                .addEventListener("click", function(){

                    let v = Math.max(1, parseInt(input.value) - 1);
                    input.value = v;

                });

                box.querySelector(".qty-increase")
                .addEventListener("click", function(){

                    let v = parseInt(input.value) + 1;
                    input.value = v;

                });

            });



            /* Add to Cart */

            document.querySelectorAll(".btn-add-cart")
            .forEach(function(btn){

                btn.addEventListener("click", function(){

                    let id = this.dataset.id;

                    let qty = this.closest(".meal-card")
                                  .querySelector(".qty-input").value;

                    fetch('/Cart/AddToCart',{
                        method:'POST',
                        headers:{'Content-Type':'application/json'},
                        body:JSON.stringify({
                            productId:id,
                            quantity:qty
                        })
                    })
                    .then(r=>r.json())
                    .then(res=>{

                        if(res.success){

                            btn.innerText="Added ✓";

                            setTimeout(()=>{
                                btn.innerText="ADD";
                            },1200);

                        }
                        else{
                            alert("Please login first");
                        }

                    });

                });

            });

        });

    </script>

}