@{
    ViewData["Title"] = "FoodBox — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var predefined = ViewBag.Predefined as IEnumerable<dynamic>;
    var groups = ViewBag.CustomGroups;
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="container py-4">

    <h2 class="mb-4">FoodBox</h2>

    <!-- PREDEFINED BOXES -->

    <h4>Predefined Boxes</h4>

    @foreach (var box in predefined)
    {

        <div class="meal-card card p-3 mb-3">

            <div class="row align-items-center">

                <div class="col-md-8">

                    <h5>@box.Name</h5>

                    <div class="price">₹@box.Price</div>

                    <p>@box.Description</p>

                </div>

                <div class="col-md-4 text-end">

                    <img src="@box.ImagePath" class="meal-img" />

                    <button class="btn-add-predefined mt-2"
                            data-id="@box.Id"
                            data-moq="20">

                        ADD

                    </button>

                </div>

            </div>

        </div>

    }

    <hr class="my-4" />


    <!-- CUSTOM FOODBOX -->

    <h4>Customized FoodBox</h4>

    <div class="custom-box card p-3 mb-4">

        <div class="row align-items-center">

            <div class="col-md-8">

                <h5>Build Your Box</h5>

                <div class="price">
                    ₹ <span id="boxPrice">0</span>
                </div>

                <p id="boxItems">No Items Selected</p>

                <button id="addCustomBox"
                        class="btn btn-success mt-2"
                        style="display:none;">
                    Add Custom Box to Cart
                </button>

            </div>

            <div class="col-md-4 text-end">

                <img id="boxImage"
                     src="/images/bulk/customize foodbox.png"
                     class="foodbox-img" />

            </div>

        </div>

    </div>


    <!-- CUSTOM ITEM CATEGORIES -->

    <div class="accordion" id="foodboxAccordion">

        @{
            int index = 0;
        }

        @foreach (var group in groups)
        {

            var heading = "heading" + index;
            var collapse = "collapse" + index;

            <div class="accordion-item">

                <h2 class="accordion-header" id="@heading">

                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapse">

                        @group.Key

                    </button>

                </h2>

                <div id="@collapse"
                     class="accordion-collapse collapse"
                     data-bs-parent="#foodboxAccordion">

                    <div class="accordion-body">

                        @foreach (var item in group)
                        {

                            <div class="foodbox-item">

                                <div class="row align-items-center">

                                    <div class="col-md-8">

                                        <h6>@item.Name</h6>

                                        ₹@item.Price

                                    </div>

                                    <div class="col-md-4 text-end">

                                        <img src="@item.ImagePath"
                                             class="meal-img" />

                                        <button class="btn-add-box"
                                                data-id="@item.Id"
                                                data-name="@item.Name"
                                                data-price="@item.Price"
                                                data-moq="25">

                                            ADD

                                        </button>

                                    </div>

                                </div>

                            </div>

                        }

                    </div>

                </div>

            </div>

            index++;

        }

    </div>

</div>


@section Scripts {

    <script>

        let selectedItems = {};
        let totalPrice = 0;


        /* ---------- GLOBAL CLICK HANDLER ---------- */

        document.addEventListener("click", function(e){

        /* ---------- PREDEFINED BOX ADD ---------- */

        if(e.target.classList.contains("btn-add-predefined")){

        let btn = e.target;
        let id = btn.dataset.id;

        btn.outerHTML = `
        <div class="qty-box predefined" data-id="${id}" data-min="20">
        <button class="minus">-</button>
        <span class="qty">20</span>
        <button class="plus">+</button>
        </div>`;

        }


        /* ---------- CUSTOM ITEM ADD ---------- */

        if(e.target.classList.contains("btn-add-box")){

        let btn = e.target;

        let name = btn.dataset.name;
        let price = parseInt(btn.dataset.price);

        selectedItems[name] = {
        price: price,
        qty: 1
        };

        updateTotal();

        btn.outerHTML = `
        <div class="qty-box custom-item" data-name="${name}" data-price="${price}" data-min="1">
        <button class="minus">-</button>
        <span class="qty">1</span>
        <button class="plus">+</button>
        </div>`;

        }


        /* ---------- FINAL CUSTOM BOX ADD ---------- */

        if(e.target.id === "addCustomBox"){

        let btn = e.target;

        btn.outerHTML = `
        <div class="qty-box custom-box" data-min="25">
        <button class="minus">-</button>
        <span class="qty">25</span>
        <button class="plus">+</button>
        </div>`;

        }


        /* ---------- PLUS BUTTON ---------- */

        if(e.target.classList.contains("plus")){

        let parent = e.target.parentElement;

        let qtyElement = parent.querySelector(".qty");

        let qty = parseInt(qtyElement.innerText) + 1;

        qtyElement.innerText = qty;

        if(parent.dataset.name){

        let name = parent.dataset.name;

        selectedItems[name].qty = qty;

        updateTotal();

        }

        }


        /* ---------- MINUS BUTTON ---------- */

        if(e.target.classList.contains("minus")){

        let parent = e.target.parentElement;

        let min = parseInt(parent.dataset.min);

        let qtyElement = parent.querySelector(".qty");

        let qty = parseInt(qtyElement.innerText);


        /* reduce quantity */

        if(qty > min){

        qtyElement.innerText = qty - 1;

        if(parent.dataset.name){

        let name = parent.dataset.name;

        selectedItems[name].qty = qty - 1;

        updateTotal();

        }

        }

        /* remove item */

        else{

        if(parent.dataset.name){

        let name = parent.dataset.name;

        delete selectedItems[name];

        updateTotal();

        }


        /* recreate ADD button */

        let addBtn = document.createElement("button");

        if(parent.classList.contains("predefined")){

        addBtn.className = "btn-add-predefined mt-2";
        addBtn.dataset.id = parent.dataset.id;

        }
        else{

        addBtn.className = "btn-add-box";

        addBtn.dataset.name = parent.dataset.name;
        addBtn.dataset.price = parent.dataset.price;

        }

        addBtn.innerText = "ADD";

        parent.replaceWith(addBtn);

        }

        }

        });


        /* ---------- UPDATE TOTAL PRICE ---------- */

        function updateTotal(){

        totalPrice = 0;

        let items = [];

        for(let key in selectedItems){

        let item = selectedItems[key];

        totalPrice += item.price * item.qty;

        items.push(`${key} x ${item.qty}`);

        }

        document.getElementById("boxPrice").innerText = totalPrice;

        document.getElementById("boxItems").innerText =
        items.length ? items.join(", ") : "No Items Selected";

        if(items.length === 0){

        document.getElementById("boxImage").src =
        "/images/bulk/customize foodbox.png";

        document.getElementById("addCustomBox").style.display = "none";

        }
        else{

        document.getElementById("boxImage").src =
        "/images/bulk/boxFilled.png";

        document.getElementById("addCustomBox").style.display = "inline-block";

        }

        }

    </script>

}