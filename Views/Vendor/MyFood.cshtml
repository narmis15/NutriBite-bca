@model List<NUTRIBITE.Models.Food>

@{
    ViewData["Title"] = "My Foods";
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/vendor-myfoods.css" asp-append-version="true" />
}

<div class="page-wrapper">

    <div class="page-header">
        <h2>My Foods</h2>
        <a asp-action="AddFood" class="add-btn">+ Add New Food</a>
    </div>

    <div class="food-grid">

        @if (Model == null || Model.Count == 0)
        {
            <p>No food items added yet.</p>
        }
        else
        {
            @foreach (var food in Model)
            {
                <div class="food-card">

                    <img class="food-image"
                         src="@food.ImagePath"
                         alt="Food">

                    <div class="food-body">
                        <h4>@food.Name</h4>

                        <div class="food-meta">
                            @food.Calories Calories · ₹@food.Price
                        </div>

                        <div class="tag">
                            @food.CategoryId
                        </div>

                        <div class="actions">
                            <a asp-action="EditFood"
                               asp-route-id="@food.Id"
                               class="btn edit">
                                Edit
                            </a>

                            <a asp-action="DeleteFood"
                               asp-route-id="@food.Id"
                               class="btn delete">
                                Delete
                            </a>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>