@{
    ViewData["Title"] = "Earnings & Payouts";
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
}

<div class="earnings-container">
    <div class="row g-4 mb-4">
        <!-- KPI Cards -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <div class="text-muted small text-uppercase fw-bold mb-2">Total Sales</div>
                <h2 class="text-primary mb-0">₹ <span id="totalEarnings">0.00</span></h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <div class="text-muted small text-uppercase fw-bold mb-2">Total Received</div>
                <h2 class="text-success mb-0">₹ <span id="totalPaid">0.00</span></h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <div class="text-muted small text-uppercase fw-bold mb-2">Commission (10%)</div>
                <h2 class="text-danger mb-0">₹ <span id="totalCommission">0.00</span></h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <div class="text-muted small text-uppercase fw-bold mb-2">Pending Payments</div>
                <h2 class="text-warning mb-0">₹ <span id="pendingPayments">0.00</span></h2>
            </div>
        </div>
    </div>

    <!-- Payouts Table -->
    <div class="card border-0 shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">Payment History</h4>
            <div class="d-flex gap-2">
                <select id="statusFilter" class="form-select form-select-sm" style="width: 150px;">
                    <option value="">All Payouts</option>
                    <option value="Pending">Pending</option>
                    <option value="PaidToVendor">Paid</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Details</th>
                        <th>Payout Period</th>
                        <th>Total Sales</th>
                        <th>Commission (10%)</th>
                        <th>Your Earnings</th>
                        <th>Status</th>
                        <th>Last Updated</th>
                    </tr>
                </thead>
                <tbody id="payoutsBody">
                    <tr>
                        <td colspan="7" class="text-center py-4">Loading payments...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <div class="text-muted small">Showing <span id="showingCount">0</span> of <span id="totalCount">0</span> payouts</div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0" id="pagination">
                    <!-- Pagination injected here -->
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        const pageSize = 20;

        async function loadEarnings() {
            console.log('Fetching earnings data...');
            try {
                const response = await fetch('/Vendor/GetEarningsData');
                if (response.ok) {
                    const data = await response.json();
                    console.log('Earnings data received:', data);
                    if (data.success === false) {
                        console.error('API Error:', data.message);
                        return;
                    }
                    document.getElementById('totalEarnings').textContent = (data.totalEarnings || 0).toFixed(2);
                    document.getElementById('totalPaid').textContent = (data.totalPaid || 0).toFixed(2);
                    document.getElementById('totalCommission').textContent = (data.totalCommissionDeducted || 0).toFixed(2);
                    document.getElementById('pendingPayments').textContent = (data.pendingPayments || 0).toFixed(2);
                } else {
                    console.error('Failed to fetch earnings:', response.status);
                }
            } catch (error) {
                console.error('Error loading earnings:', error);
            }
        }

        async function loadPayouts(page = 1) {
            console.log('Fetching payouts data for page:', page);
            const status = document.getElementById('statusFilter').value;
            try {
                const response = await fetch(`/Vendor/GetPayoutsData?page=${page}&pageSize=${pageSize}&status=${status}`);
                if (response.ok) {
                    const data = await response.json();
                    console.log('Payouts data received:', data);
                    if (data.success === false) {
                        console.error('API Error:', data.message);
                        return;
                    }
                    renderPayouts(data.items || []);
                    renderPagination(data.totalItems || 0, data.page || 1, data.pageSize || 20);
                    document.getElementById('showingCount').textContent = (data.items || []).length;
                    document.getElementById('totalCount').textContent = data.totalItems || 0;
                    currentPage = data.page || 1;
                } else {
                    console.error('Failed to fetch payouts:', response.status);
                }
            } catch (error) {
                console.error('Error loading payouts:', error);
            }
        }

        function renderPayouts(payouts) {
            const body = document.getElementById('payoutsBody');
            if (payouts.length === 0) {
                body.innerHTML = '<tr><td colspan="7" class="text-center py-4">No payouts found.</td></tr>';
                return;
            }

            body.innerHTML = payouts.map(p => `
                <tr>
                    <td>
                        ${p.id === 0 ? `<span class="badge bg-warning-subtle text-warning border">Live Balance</span>` :
                          (p.orderId ? `<span class="badge bg-light text-dark border">Order #${p.orderId}</span>` : `<span class="badge bg-primary">Aggregate Payout</span>`)}
                        <div class="text-muted extra-small">ID: ${p.id === 0 ? 'ACC-NEW' : '#' + p.id}</div>
                    </td>
                    <td>
                        <div class="fw-bold">${p.payoutMonth || 'N/A'}</div>
                        <div class="text-muted small">${p.orderDate ? new Date(p.orderDate).toLocaleDateString() : ''}</div>
                    </td>
                    <td>₹${p.totalSales.toFixed(2)}</td>
                    <td class="text-danger">- ₹${p.commissionDeducted.toFixed(2)}</td>
                    <td class="fw-bold text-success">₹${p.amount.toFixed(2)}</td>
                    <td>
                        <span class="badge ${p.status === 'Pending' || p.status === 'Accruing' ? 'bg-warning-subtle text-warning' : 'bg-success-subtle text-success'}">
                            ${p.status === 'PaidToVendor' ? 'Paid' : (p.status === 'Accruing' ? 'Live Balance' : p.status)}
                        </span>
                    </td>
                    <td class="text-muted small">${new Date(p.updatedAt).toLocaleString()}</td>
                </tr>
            `).join('');
        }

        function renderPagination(totalItems, page, size) {
            const totalPages = Math.ceil(totalItems / size);
            const pagination = document.getElementById('pagination');
            
            let html = '';
            for (let i = 1; i <= totalPages; i++) {
                html += `
                    <li class="page-item ${i === page ? 'active' : ''}">
                        <button class="page-link" onclick="loadPayouts(${i})">${i}</button>
                    </li>
                `;
            }
            pagination.innerHTML = html;
        }

        document.getElementById('statusFilter').addEventListener('change', () => loadPayouts(1));

        // Initial Load
        loadEarnings();
        loadPayouts();
    </script>
}
