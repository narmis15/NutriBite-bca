@model NUTRIBITE.Models.VendorSignup
@{
    ViewData["Title"] = "Vendor Profile";
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
}

<div class="row g-4">

    <!-- LEFT PROFILE SUMMARY -->
    <div class="col-md-4">
        <div class="vendor-card profile-summary text-center h-100 shadow-sm">
            <div class="profile-avatar-container position-relative mb-3">
                <div class="profile-avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto shadow mb-3" style="width: 120px; height: 120px; font-size: 3rem;">
                    @Model.VendorName.Substring(0, 1).ToUpper()
                </div>
            </div>
            <h4 class="fw-bold mb-1">@Model.VendorName</h4>
            <p class="text-muted mb-3">@Model.Email</p>
            <div class="mb-4">
                @if (Model.IsApproved)
                {
                    <span class="badge bg-success-soft text-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i> Approved Vendor</span>
                }
                else
                {
                    <span class="badge bg-warning-soft text-warning px-3 py-2 rounded-pill"><i class="bi bi-clock-fill me-1"></i> Pending Approval</span>
                }
            </div>
            
            <div class="text-start px-3 border-top pt-3">
                <p class="mb-2"><i class="bi bi-telephone text-primary me-2"></i> @(Model.Phone ?? "No phone added")</p>
                <p class="mb-2"><i class="bi bi-geo-alt text-danger me-2"></i> @(Model.Address ?? "No address added")</p>
                <p class="mb-2"><i class="bi bi-clock text-info me-2"></i> @(Model.OpeningHours ?? "09:00") - @(Model.ClosingHours ?? "21:00")</p>
                <p class="mb-0"><i class="bi bi-wallet2 text-success me-2"></i> @(Model.UpiId ?? "UPI ID not set")</p>
            </div>
        </div>
    </div>

    <!-- RIGHT EDIT FORM -->
    <div class="col-md-8">
        <div class="vendor-card shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                <h5 class="fw-bold mb-0">Professional Store Information</h5>
                <small class="text-muted">Last updated: @(Model.CreatedAt?.ToString("dd MMM yyyy"))</small>
            </div>

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Profile" method="post" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Store Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shop text-muted"></i></span>
                            <input type="text" name="vendorName" class="form-control border-start-0" value="@Model.VendorName" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Contact Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input type="email" name="email" class="form-control border-start-0" value="@Model.Email" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Store Phone</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone text-muted"></i></span>
                            <input type="text" name="phone" class="form-control border-start-0" value="@Model.Phone" placeholder="+91 98765-43210">
                        </div>
                    </div>
                    
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">UPI ID (for payments)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-wallet2 text-muted"></i></span>
                            <input type="text" name="upiId" class="form-control border-start-0" value="@Model.UpiId" placeholder="vendor@upi">
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Store Description</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Describe your kitchen and specialties...">@Model.Description</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Store Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
                            <textarea name="address" class="form-control border-start-0" rows="2" placeholder="Full store address...">@Model.Address</textarea>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Opening Time</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-clock text-muted"></i></span>
                            <input type="time" name="openingHours" class="form-control border-start-0" value="@Model.OpeningHours">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Closing Time</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-clock-history text-muted"></i></span>
                            <input type="time" name="closingHours" class="form-control border-start-0" value="@Model.ClosingHours">
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-primary px-5 shadow">
                        <i class="bi bi-save me-2"></i> Update Professional Profile
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

</div>