@{
    ViewData["Title"] = "Vendor";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Vendor.css" asp-append-version="true" />
}

<div class="vendor-auth-wrapper">
    <div class="vendor-auth-card">

        <div class="vendor-left">
            <h2>Join NutriBite</h2>
            <p>
                Start selling healthy homemade meals.
                Manage your orders and grow your business.
            </p>
        </div>

        <div class="vendor-right">
            <h3 class="brand">NutriBite</h3>
            <h5 class="mb-3">Create Vendor Account</h5>

            <form method="post" asp-action="Register">

                <div class="mb-3">
                    <label>Vendor Name</label>
                    <input type="text" name="VendorName" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input type="email" name="Email" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <div class="input-group">
                        <input id="password" type="password" name="Password" class="form-control custom-input" required />
                        <button id="togglePasswordReg" class="btn btn-outline-secondary d-flex align-items-center" type="button"><i class="bi bi-eye"></i></button>
                    </div>
                </div>

                <div class="mb-3">
                    <label>Confirm Password</label>
                    <div class="input-group">
                        <input id="confirmPassword" type="password" name="ConfirmPassword" class="form-control custom-input" required />
                        <button id="toggleConfirmReg" class="btn btn-outline-secondary d-flex align-items-center" type="button"><i class="bi bi-eye"></i></button>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100 mt-2">
                    Register
                </button>

                <div class="auth-links">
                    <a href="/Vendor/Login">Already have an account?</a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $('#togglePasswordReg').on('click', function () {
            const $pwd = $('#password');
            const type = $pwd.attr('type') === 'password' ? 'text' : 'password';
            $pwd.attr('type', type);
            $(this).html(type === 'password' ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>');
        });

        $('#toggleConfirmReg').on('click', function () {
            const $pwd = $('#confirmPassword');
            const type = $pwd.attr('type') === 'password' ? 'text' : 'password';
            $pwd.attr('type', type);
            $(this).html(type === 'password' ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>');
        });
    </script>
}
