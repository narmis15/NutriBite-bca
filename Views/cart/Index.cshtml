@model List<NUTRIBITE.Models.CartItem>

@{
    ViewData["Title"] = "Your Cart";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container py-5">
    <h2 class="mb-4 fw-bold">🛒 Your Cart</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h4>Your cart is empty</h4>
            <a href="/Home" class="btn btn-success mt-3">Explore Menu</a>
        </div>
    }
    else
    {
        <div class="row">

            <!-- CART ITEMS -->
            <div class="col-lg-8">

                @foreach (var item in Model)
                {
                    <div class="card mb-3 shadow-sm border-0 rounded-4">
                        <div class="row g-0 align-items-center">

                            <!-- IMAGE -->
                            <div class="col-md-3">
                                <img src="@item.ImageUrl"
                                     class="img-fluid rounded-start"
                                     style="height:120px; object-fit:cover;">
                            </div>

                            <!-- FOOD INFO -->
                            <div class="col-md-5">
                                <div class="card-body">

                                    <h5>@item.Name</h5>
                                    <p class="text-muted mb-2">₹ @item.Price</p>

                                </div>
                            </div>

                            <!-- UPDATE / REMOVE -->
                            <div class="col-md-4 text-center">

                                <form method="post" asp-action="UpdateQuantity">

                                    <input type="hidden" name="id" value="@item.Id" />

                                    <!-- Preferences moved into form for binding -->
                                    <div class="bg-light p-2 rounded small text-start mb-2">
                                        <strong class="text-muted d-block mb-1">Update Preferences</strong>
                                        
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="lessOil" value="Less Oil" @(item.SpecialInstructions?.Contains("Less Oil") == true ? "checked" : "")>
                                            <label class="form-check-label">Less Oil</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="lessSalt" value="Less Salt" @(item.SpecialInstructions?.Contains("Less Salt") == true ? "checked" : "")>
                                            <label class="form-check-label">Less Salt</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="lessSpicy" value="Less Spicy" @(item.SpecialInstructions?.Contains("Less Spicy") == true ? "checked" : "")>
                                            <label class="form-check-label">Less Spicy</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="noOnion" value="No Onion" @(item.SpecialInstructions?.Contains("No Onion") == true ? "checked" : "")>
                                            <label class="form-check-label">No Onion</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="noGarlic" value="No Garlic" @(item.SpecialInstructions?.Contains("No Garlic") == true ? "checked" : "")>
                                            <label class="form-check-label">No Garlic</label>
                                        </div>
                                    </div>

                                    <input type="number"
                                           name="qty"
                                           value="@item.Quantity"
                                           min="1"
                                           class="form-control mb-2 text-center" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-success w-100">
                                        Update Cart
                                    </button>

                                </form>

                                <form method="post" asp-action="Remove" class="mt-2">

                                    <input type="hidden" name="id" value="@item.Id" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger w-100">
                                        Remove Item
                                    </button>

                                </form>

                            </div>

                        </div>
                    </div>
                }

            </div>


            <!-- ORDER SUMMARY -->
            <div class="col-lg-4">

                <div class="card shadow-sm border-0 rounded-4 p-4">

                    <h5 class="fw-bold">Order Summary</h5>
                    <hr />

                    @{
                        var total = Model.Sum(x => x.Price * x.Quantity);
                    }

                    <div class="d-flex justify-content-between">
                        <span>Total:</span>
                        <span class="fw-bold">₹ @total</span>
                    </div>

                    <!-- Navigate to GET Checkout so Razorpay flow can run -->
                    <a href="@Url.Action("Checkout", "Cart")"
                       class="btn btn-success w-100 mt-4">
                        Proceed to Checkout
                    </a>

                </div>

            </div>

        </div>
    }
</div>