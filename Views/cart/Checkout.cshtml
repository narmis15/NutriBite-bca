@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Checkout — NutriBite";
    
    var subtotal = (ViewBag.Subtotal as decimal?) ?? 0m;
    var deliveryCharge = (ViewBag.DeliveryCharge as decimal?) ?? 0m;
    var gst = (ViewBag.GST as decimal?) ?? 0m;
    var totalAmount = (ViewBag.TotalAmount as decimal?) ?? 0m;
    
    var totalInvariant = totalAmount.ToString(System.Globalization.CultureInfo.InvariantCulture);
}

<div class="container py-4">
    <h2 class="mb-3">Checkout</h2>

    <div class="card p-4 mb-3 border-0 shadow-sm">
        <h4 class="fw-bold mb-3">Order Summary</h4>
        <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Subtotal</span>
            <span>₹@subtotal.ToString("N2")</span>
        </div>
        <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Delivery Fee</span>
            @if (deliveryCharge == 0)
            {
                <span class="text-success fw-bold">FREE</span>
            }
            else
            {
                <span>₹@deliveryCharge.ToString("N2")</span>
            }
        </div>
        <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">GST (5%)</span>
            <span>₹@gst.ToString("N2")</span>
        </div>
        <hr class="my-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">Grand Total</h5>
            <h5 class="fw-bold text-dark mb-0 fs-4">
                @if (ViewBag.IsBulkOrder == true)
                {
                    <span class="text-danger small text-decoration-line-through me-2">₹@(((decimal)ViewBag.OriginalTotal).ToString("N2"))</span>
                    <br/><span class="small text-muted">(50% Advance Deposit)</span>
                }
                ₹@totalAmount.ToString("N2")
            </h5>
        </div>
        @if (subtotal < 500 && ViewBag.IsBulkOrder != true)
        {
            <div class="mt-3 p-2 bg-light rounded-3 small text-center text-primary">
                <i class="bi bi-info-circle me-1"></i> Add items worth <b>₹@(500 - subtotal)</b> more for <b>FREE Delivery!</b>
            </div>
        }
        @if (ViewBag.IsBulkOrder == true)
        {
            <div class="mt-3 p-2 bg-warning bg-opacity-10 rounded-3 small text-center text-warning" style="color: #c98800 !important;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> <b>Notice:</b> Bulk orders require a 24-hour lead time for fulfillment. 
                You are paying a 50% upfront deposit to confirm the order.
            </div>
        }
    </div>

    <div class="card p-4 mb-3 shadow-sm border-0">
        <h4 class="mb-3">Delivery Details</h4>
        <div id="deliverySection">
            <div class="card bg-light border-0 p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label fw-bold mb-0 text-dark">
                        <i class="bi bi-map"></i> Delivery Address <span class="text-danger">*</span>
                    </label>
                    <button type="button" id="getLocationBtn" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                        <i class="bi bi-geo-alt-fill"></i> Get Current Location
                    </button>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <textarea id="deliveryAddress" class="form-control border-2 shadow-sm" rows="3" 
                                  placeholder="Example: Flat 402, Green Valley Apts, Sector 12, Noida..." 
                                  style="font-size: 1.1rem;"></textarea>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label small fw-bold text-muted mb-1">Pincode</label>
                            <input type="text" id="deliveryPincode" class="form-control border-2 shadow-sm" 
                                   placeholder="226020" maxlength="6" style="font-size: 1.1rem; font-weight: bold; color: #2d6a4f;">
                        </div>
                    </div>
                </div>
                
                <label class="form-label fw-bold text-dark mb-2">
                    <i class="bi bi-chat-left-text"></i> Delivery Notes (Optional)
                </label>
                <textarea id="deliveryNotes" class="form-control border-1" rows="2" 
                          placeholder="Example: Near the blue gate, Don't ring the bell, Leave at the door..."></textarea>
                
                <div class="mt-3 text-success fw-bold small">
                    <i class="bi bi-check-circle"></i> Delivery within 5km radius only.
                </div>
            </div>
        </div>
    </div>

    <div class="card p-4 mb-3 shadow-sm border-0">
        <h4 class="mb-3">Payment Method</h4>
        <div class="row g-3">
            <div class="col-md-12">
                <div class="form-check card-glass p-3 border rounded-3 h-100 bg-light bg-opacity-50">
                    <input class="form-check-input ms-0" type="radio" name="paymentMethod" id="payOnline" value="Online" checked>
                    <label class="form-check-label ms-4 w-100" for="payOnline">
                        <div class="fw-bold text-success"><i class="bi bi-shield-check"></i> Secure Online Payment</div>
                        <small class="text-muted">UPI, Cards, Net Banking (via Razorpay)</small>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <button id="payNowBtn" class="btn btn-primary btn-lg px-5 shadow-sm">
            Proceed to Pay ₹@totalAmount.ToString("N2")
        </button>
        <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary ms-2">Back to Cart</a>
    </div>

    <div id="paymentAlerts">
        <!-- Alerts injected here -->
    </div>
</div>

@section Scripts {
<script>
(function () {
    const amountMajor = parseFloat('@totalInvariant'); // major units
    const payBtn = document.getElementById('payNowBtn');
    const alertsRoot = document.getElementById('paymentAlerts');

    function updateButtonText() {
        payBtn.innerText = 'Proceed to Pay ₹' + parseFloat('@totalInvariant').toFixed(2);
    }

    // Toggle Payment Method UI (Simplified since only Online exists)
    updateButtonText();

    // Geolocation Handler
    let accuracyFailCount = 0;
    const MAX_ACCURACY_FAILS = 3;
    const TARGET_ACCURACY_METERS = 15;

    document.getElementById('getLocationBtn').addEventListener('click', async function() {
        const btn = this;
        const addressField = document.getElementById('deliveryAddress');
        
        if (!navigator.geolocation) {
            alert('Geolocation is not supported by your browser');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Fetching...';

        const options = { 
            enableHighAccuracy: true, 
            timeout: 15000, 
            maximumAge: 0 
        };

        let watchId = null;
        let bestPosition = null;

        const getBestLocation = () => new Promise((resolve, reject) => {
            // Initial quick grab
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    bestPosition = pos;
                    if (pos.coords.accuracy <= TARGET_ACCURACY_METERS) resolve(pos);
                },
                (err) => console.warn("Initial position error:", err),
                options
            );

            // Watch for improvements
            watchId = navigator.geolocation.watchPosition(
                (pos) => {
                    if (!bestPosition || pos.coords.accuracy < bestPosition.coords.accuracy) {
                        bestPosition = pos;
                    }
                    if (pos.coords.accuracy <= TARGET_ACCURACY_METERS) {
                        navigator.geolocation.clearWatch(watchId);
                        resolve(pos);
                    }
                },
                (err) => {
                    if (bestPosition) resolve(bestPosition);
                    else reject(err);
                },
                options
            );

            // Safety timeout
            setTimeout(() => {
                if (watchId) navigator.geolocation.clearWatch(watchId);
                if (bestPosition) resolve(bestPosition);
                else reject({ code: 3, message: "Location timeout" });
            }, 10000);
        });

        try {
            const position = await getBestLocation();
            const { latitude, longitude, accuracy } = position.coords;
            console.log(`Location detected: ${latitude}, ${longitude} (Accuracy: ${accuracy}m)`);

            if (accuracy > TARGET_ACCURACY_METERS) {
                accuracyFailCount++;
                if (accuracyFailCount >= MAX_ACCURACY_FAILS) {
                    showAlert('warning', `<i class="bi bi-exclamation-triangle"></i> Accuracy is ${Math.round(accuracy)}m. Please verify the pincode manually.`);
                    accuracyFailCount = 0;
                }
            } else {
                accuracyFailCount = 0;
            }

            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latitude}&lon=${longitude}&zoom=18&addressdetails=1`, {
                    headers: { 'Accept-Language': 'en-US,en;q=0.9' }
                });
                const data = await response.json();
                
                // Phase 3: Store for backend geofencing
                window.checkoutLat = latitude;
                window.checkoutLng = longitude;
                
                if (data && data.display_name) {
                    // Extract pincode if available
                    const pincode = data.address?.postcode || "";
                    if (pincode) {
                        document.getElementById('deliveryPincode').value = pincode;
                        document.getElementById('deliveryPincode').classList.add('is-valid');
                    }

                    // Remove pincode from display name if it exists to avoid duplication
                    let finalAddress = data.display_name;
                    if (pincode && finalAddress.includes(pincode)) {
                        finalAddress = finalAddress.replace(new RegExp(`,?\\s*${pincode}`, 'g'), '').trim();
                    }

                    addressField.value = finalAddress;
                    addressField.classList.remove('is-invalid');
                    addressField.classList.add('is-valid');
                    
                    showAlert('success', '<i class="bi bi-check-circle"></i> Location detected. Please verify your Pincode and Address.', 3000);
                } else {
                    addressField.value = `Latitude: ${latitude}, Longitude: ${longitude}`;
                }
            } catch (error) {
                console.error('Reverse geocoding failed:', error);
                addressField.value = `Latitude: ${latitude}, Longitude: ${longitude}`;
            }
            
        } catch (error) {
            console.error(`Geolocation failed:`, error);
            if (error.code === 1) alert('Location access denied. Please enable permissions.');
            else alert('Unable to retrieve your location. Please enter it manually.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i> Get Current Location';
        }
    });

    function clearAlerts() {
        alertsRoot.innerHTML = '';
    }

    function showAlert(type, html, autoHideMs = 0) {
        clearAlerts();
        const wrapper = document.createElement('div');
        wrapper.className = `alert alert-${type} alert-dismissible fade show`;
        wrapper.setAttribute('role', 'alert');
        wrapper.innerHTML = html + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
        alertsRoot.appendChild(wrapper);

        if (autoHideMs > 0) {
            setTimeout(() => {
                try { bootstrap.Alert.getOrCreateInstance(wrapper).close(); } catch {}
            }, autoHideMs);
        }
    }

    function loadScript(src) {
        return new Promise((resolve, reject) => {
            if (document.querySelector(`script[src="${src}"]`)) return resolve();
            const s = document.createElement('script');
            s.src = src;
            s.onload = () => resolve();
            s.onerror = () => reject(new Error('Failed to load ' + src));
            document.head.appendChild(s);
        });
    }

    async function createRazorpayOrder() {
        const res = await fetch('/Payment/CreateOrder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({}) // server computes cart total
        });

        if (!res.ok) {
            const payload = await res.json().catch(()=>({}));
            throw new Error(payload?.message || 'Failed to create order');
        }

        return res.json();
    }

    async function verifyPayment(payload, localOrderId) {
        const res = await fetch('/Payment/VerifyPayment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...payload, localOrderId: localOrderId })
        });

        return res.json();
    }

    async function finalizeOrderOnServer(clearCart = true) {
        const orderType = 'Delivery';
        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
        let deliveryAddress = document.getElementById('deliveryAddress').value;
        const deliveryPincode = document.getElementById('deliveryPincode').value;
        const deliveryNotes = document.getElementById('deliveryNotes').value;

        if (!deliveryAddress.trim()) {
            document.getElementById('deliveryAddress').classList.add('is-invalid');
            throw new Error('Please enter a delivery address to proceed.');
        } else {
            document.getElementById('deliveryAddress').classList.remove('is-invalid');
        }

        if (!deliveryPincode.trim() || deliveryPincode.length < 6) {
            document.getElementById('deliveryPincode').classList.add('is-invalid');
            throw new Error('Please enter a valid 6-digit Pincode.');
        } else {
            document.getElementById('deliveryPincode').classList.remove('is-invalid');
        }

        // Combine address and pincode for final storage
        const finalFullAddress = `${deliveryAddress.trim()}, Pincode: ${deliveryPincode.trim()}`;

        // Create local order and clear cart using existing flow
        const response = await fetch('/Cart/Checkout', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: new URLSearchParams({ 
                pickupSlot: '',
                orderType: orderType,
                deliveryAddress: finalFullAddress,
                deliveryNotes: deliveryNotes,
                paymentMethod: paymentMethod,
                clearCart: clearCart,
                latitude: window.checkoutLat || '',
                longitude: window.checkoutLng || ''
            }).toString()
        });

        if (!response.ok) {
            throw new Error('Failed to finalize order on server');
        }

        const data = await response.json();
        if (!data.success) {
            throw new Error(data.message || 'Order creation failed');
        }
        return data.orderId;
    }

    async function startPaymentFlow() {
        clearAlerts();
        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
        payBtn.disabled = true;
        payBtn.innerText = 'Processing...';

        try {
            if (amountMajor <= 0) {
                showAlert('danger', 'Cart total invalid. Please add items to cart.');
                payBtn.disabled = false;
                updateButtonText();
                return;
            }

            // Online Payment Flow (Razorpay)
            // 1. Create local order first to get localOrderId, but DON'T clear cart yet
            const localOrderId = await finalizeOrderOnServer(false);

            // 2. Create Razorpay order
            const orderResp = await createRazorpayOrder();

            if (!orderResp || !orderResp.success) {
                throw new Error(orderResp?.message || 'Could not create payment order.');
            }

            await loadScript('https://checkout.razorpay.com/v1/checkout.js');

            // build options
            const options = {
                key: orderResp.keyId,
                amount: orderResp.amount,
                currency: orderResp.currency || 'INR',
                name: 'NutriBite',
                description: 'Food Order Payment',
                order_id: orderResp.orderId,
                handler: async function (response) {
                    try {
                        // verify payment on server
                        const verifyPayload = {
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_signature: response.razorpay_signature
                        };

                        const verifyResult = await verifyPayment(verifyPayload, localOrderId);

                        if (!verifyResult || !verifyResult.success) {
                            showAlert('danger',
                                `<strong>Payment verification failed.</strong> ${verifyResult?.message || ''} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`
                            );
                            attachRetry();
                            payBtn.disabled = false;
                            updateButtonText();
                            return;
                        }

                        // show success message with brief delay, then redirect to confirmation
                        showAlert('success', `<strong>Payment successful.</strong> Payment ID: <code>${verifyResult.paymentId}</code>. Redirecting to confirmation...`, 4000);

                        setTimeout(() => {
                            window.location.href = '/Cart/Success';
                        }, 2000);
                    } catch (err) {
                        console.error(err);
                        showAlert('danger', `<strong>Processing failed.</strong> ${err.message || ''} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`);
                        attachRetry();
                        payBtn.disabled = false;
                        updateButtonText();
                    }
                },
                prefill: {
                    name: '@(User?.Identity?.IsAuthenticated == true ? User.Identity.Name : "")'
                },
                theme: { color: '#2d6a4f' }
            };

            const rzp = new Razorpay(options);

            rzp.on('payment.failed', function (response){
                // show friendly failure with retry option
                showAlert('danger', `<strong>Payment failed.</strong> ${response.error?.description || ''} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`);
                attachRetry();
                payBtn.disabled = false;
                updateButtonText();
            });

            rzp.open();
        } catch (err) {
            console.error(err);
            showAlert('danger', `<strong>Error:</strong> ${err.message || 'Unable to initiate payment.'} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`);
            attachRetry();
            payBtn.disabled = false;
            updateButtonText();
        }
    }

    function attachRetry() {
        const retry = document.getElementById('retryBtn');
        if (!retry) return;
        retry.addEventListener('click', function () {
            clearAlerts();
            startPaymentFlow();
        });
    }

    // initial button text ensured
    updateButtonText();
    payBtn.addEventListener('click', startPaymentFlow);
})();
</script>
}